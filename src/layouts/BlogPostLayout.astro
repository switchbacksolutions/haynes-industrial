---
/**
 * BlogPostLayout.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Layout for individual blog posts. Receives the full CollectionEntry for a
 * blog post and renders the hero image, metadata, tags, and prose content.
 *
 * Used by src/pages/blog/[...slug].astro.
 */

import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <!-- Hero image -->
    {heroImage && (
      <div class="mb-8 overflow-hidden rounded-xl">
        <img
          src={heroImage}
          alt={`Hero image for ${title}`}
          class="w-full object-cover"
          width={1200}
          height={630}
          loading="eager"
        />
      </div>
    )}

    <!-- Post header -->
    <header class="mb-8">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )}

      <h1 class="text-4xl font-bold leading-tight text-gray-900 dark:text-white text-balance">
        {title}
      </h1>

      <p class="mt-3 text-lg text-gray-600 dark:text-gray-400 text-pretty">
        {description}
      </p>

      <!-- Dates -->
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
        <span class="flex items-center gap-1.5">
          <span class="text-gray-500 dark:text-gray-400">Published</span>
          <FormattedDate date={pubDate} />
        </span>

        {updatedDate && updatedDate > pubDate && (
          <span class="flex items-center gap-1.5 text-gray-500 dark:text-gray-400">
            <span>·</span>
            <span>Updated</span>
            <FormattedDate date={updatedDate} />
          </span>
        )}
      </div>
    </header>

    <!-- Divider -->
    <hr class="mb-10 border-gray-200 dark:border-gray-700" />

    <!-- Post body (rendered Markdown / MDX) -->
    <div class="prose-content">
      <slot />
    </div>

    <!-- Back link -->
    <div class="mt-12 border-t border-gray-200 pt-8 dark:border-gray-700">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium text-brand-600 no-underline hover:underline dark:text-brand-400"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to all posts
      </a>
    </div>
  </article>
</BaseLayout>
