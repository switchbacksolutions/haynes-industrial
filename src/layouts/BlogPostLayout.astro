---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;
---

<BaseLayout title={title} description={description} image={heroImage}>

  <!-- Post header banner -->
  <div class="bg-brand-900 py-16">
    <div class="section-container">
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )}
      <h1 class="text-4xl font-bold text-white leading-tight text-balance md:text-5xl max-w-3xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-brand-300 max-w-2xl text-pretty">
        {description}
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs font-semibold uppercase tracking-wider text-brand-400">
        <FormattedDate date={pubDate} />
        {updatedDate && updatedDate > pubDate && (
          <>
            <span>·</span>
            <span>Updated <FormattedDate date={updatedDate} /></span>
          </>
        )}
      </div>
    </div>
  </div>

  <article class="py-16">
    <div class="section-container">

      <!-- Hero image -->
      {heroImage && (
        <div class="mb-12 overflow-hidden">
          <img
            src={heroImage}
            alt={`Hero image for ${title}`}
            class="w-full object-cover"
            width={1200}
            height={630}
            loading="eager"
          />
        </div>
      )}

      <!-- Post body -->
      <div class="mx-auto max-w-3xl">
        <div class="prose-content">
          <slot />
        </div>

        <!-- Back link -->
        <div class="mt-16 border-t border-gray-200 pt-8">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-semibold text-brand-600 no-underline hover:underline"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
              class="h-4 w-4"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
            Back to all posts
          </a>
        </div>
      </div>

    </div>
  </article>

</BaseLayout>
