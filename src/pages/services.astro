---
import BaseLayout from '@/layouts/BaseLayout.astro';

interface SubService {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  href?: string;
}

interface ServiceCategory {
  id: string;
  eyebrow: string;
  title: string;
  href?: string;
  image?: string;
  imageAlt?: string;
  description: string;
  dark: boolean;
  subservices: SubService[];
}

const services: ServiceCategory[] = [
  {
    id: 'hvac-recycling',
    eyebrow: 'Service 01',
    title: 'HVAC Recycling',
    href: '/services/hvac-recycling',
    image: '/images/hvac-crane-removal.avif',
    imageAlt: 'Commercial HVAC unit being crane-lifted for removal',
    description: 'Commercial HVAC decommissioning with EPA 608 certified refrigerant recovery on-site. Rooftop units, chillers, and split systems — we recover the refrigerant, handle crane logistics for rooftop lifts, and pay you for the recovered copper, aluminum, and steel.',
    dark: false,
    subservices: [
      {
        title: 'EPA 608 Refrigerant Recovery',
        description: 'Certified refrigerant recovery on-site before removal — no separate tech needed. R-22, R-410A, R-134a, and all common refrigerants.',
      },
      {
        title: 'Crane Logistics for Rooftop Units',
        description: 'We coordinate the crane and rigging for large rooftop units that require lift-off. One call handles refrigerant recovery, the lift, and material transport.',
      },
      {
        title: 'Material Recovery & Payment',
        description: 'Commercial HVAC equipment contains substantial copper, aluminum, and steel. We pay for recovered material at current commodity rates.',
      },
    ],
  },
  {
    id: 'ewaste',
    eyebrow: 'Service 02',
    title: 'E-Waste / Electronics Recycling',
    href: '/services/ewaste',
    image: '/images/wire-ewaste.avif',
    imageAlt: 'Wire and electronic waste ready for processing',
    description: 'Certified data destruction and responsible downstream handling for businesses decommissioning electronics. CEW registered with Cal Recycle / DTSC. We pay for gold-bearing components and haul everything else at no charge.',
    dark: true,
    subservices: [
      {
        title: 'Data Destruction Certificates',
        description: 'Physical shredding or certified multi-pass wipe — certificate issued per device by serial number. Your compliance team gets the documentation they need.',
      },
      {
        title: 'Gold-Bearing Component Buy-Back',
        description: 'CPUs, RAM, server boards, telecom cards — we buy the high-value material. End-of-life equipment we haul for free.',
      },
      {
        title: 'B2B Pickup, Sacramento Region',
        description: 'We come to your facility. IT departments, repair shops, municipalities, schools, and healthcare — any organization with a volume of electronics to move.',
      },
    ],
  },
  {
    id: 'metal-recycling',
    eyebrow: 'Service 03',
    title: 'Metal Recycling',
    href: '/services/metal-recycling',
    image: '/images/loaded-truck-pipe.avif',
    imageAlt: 'Industrial truck loaded with metal pipe for recycling',
    description: 'Industrial metal recycling pickup for licensed contractors throughout Northern California. Copper, aluminum, steel, and more — we come to your job site. Pricing tied to current commodity spot rates, explained before we load. Same-week scheduling.',
    dark: false,
    subservices: [
      {
        title: 'Ferrous Metals',
        description: 'Steel piping, structural steel, rebar, and sheet steel from renovation, demolition, and industrial jobs.',
      },
      {
        title: 'Non-Ferrous Metals',
        description: 'Copper (bare bright, #1, #2), aluminum (sheet, extrusion, cast), brass, lead, and stainless steel.',
      },
      {
        title: 'Specialty Items',
        description: 'Refrigerant recovery units (EPA 608), forklift and industrial batteries, electric motors, transformers, and copper wiring.',
      },
    ],
  },
  {
    id: 'industrial-surplus',
    eyebrow: 'Service 04',
    title: 'Industrial Surplus Buying',
    href: '/services/industrial-surplus',
    image: '/images/forklift-wire-bin.avif',
    imageAlt: 'Forklift moving industrial surplus material',
    description: 'We buy surplus equipment, chemicals, raw materials, tooling, and stranded inventory. You send a list, we assess, we pick it up, you get paid. No auction, no vetting buyers, no hauling.',
    dark: true,
    subservices: [
      {
        title: 'Industrial Equipment',
        description: 'Machine tools, pumps, motors, compressors, generators, conveyors, HVAC units, and forklifts.',
      },
      {
        title: 'Surplus Chemicals & Raw Materials',
        description: 'Industrial lubricants, solvents, agricultural chemicals, metal stock, plastic resin, and fasteners (SDS required for chemicals).',
      },
      {
        title: 'Stranded & Discontinued Inventory',
        description: 'Obsolete SKUs, customer-abandoned freight, off-spec product, packaging, pallets, drums, and IBC totes.',
      },
    ],
  },
  {
    id: 'pallets-and-gaylords',
    eyebrow: 'Service 05',
    title: 'Pallets & Gaylords',
    href: '/services/pallets-and-gaylords',
    image: '/images/worker-loading-trailer.gif',
    imageAlt: 'Worker loading material onto a trailer for pickup',
    description: 'We buy surplus pallets, gaylord bulk bins, IBC totes, and packaging material. Wood and plastic pallets, one-trip and used gaylords, drums — same-week pickup throughout the Sacramento region. Recurring accounts available for high-volume docks.',
    dark: true,
    subservices: [
      {
        title: 'Wood & Plastic Pallets',
        description: 'GMA 48×40, heat-treated (ISPM-15), custom sizes, and plastic pallets. Good repair commands the best rate; broken pallets go to commodity recovery.',
      },
      {
        title: 'Gaylords & Bulk Bins',
        description: 'Single, double, and triple-wall corrugated gaylords. One-trip and lightly used bins get the best price; heavily used bins still pay at corrugated commodity rates.',
      },
      {
        title: 'Recurring Dock Accounts',
        description: 'Set-and-forget pickup schedule for facilities that accumulate pallets or gaylords on a regular cycle. Agreed pricing upfront — no renegotiating every visit.',
      },
    ],
  },
  {
    id: 'general-logistics',
    eyebrow: 'Service 06',
    title: 'General Logistics',
    href: '/services/general-logistics',
    image: '/images/haynes-industrial-truck-loaded.jpeg',
    imageAlt: 'Haynes Industrial truck loaded with material at a job site',
    description: 'Licensed transportation provider for manufacturers, importers, distributors, and facilities throughout Northern California. We arrange the right carrier for every load — complex material, regulated freight, and recurring accounts.',
    dark: false,
    subservices: [
      {
        title: 'Transportation Coordination',
        description: 'We source from the full carrier market, not a single fleet — more options, faster scheduling, and the right equipment for every load.',
      },
      {
        title: 'Warehouse Storage & Cross-Dock',
        description: 'Short- and mid-term storage in the Sacramento region. Stage material before a move, hold freight between legs, or buffer inventory as needed.',
      },
      {
        title: 'Facility Transition Logistics',
        description: 'Relocating, closing, or consolidating? We coordinate inbound and outbound freight, surplus removal, and disposition so you\'re not managing multiple vendors.',
      },
    ],
  },
];
---

<BaseLayout
  title="Services"
  description="Recycling logistics services across Northern and Central California — transportation, compliance, metal recycling, e-waste, and industrial surplus buying. We handle the logistics of getting maximum value from your end-of-life and surplus material."
>
  <main>

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section class="relative isolate overflow-hidden min-h-[60vh] flex items-end">
      <img
        src="/images/loaded-truck.avif"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
        fetchpriority="high"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-900/80 to-brand-900/20"></div>
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-brand-900/95 via-brand-900/40 to-transparent"></div>
      <div class="w-full">
        <div class="section-container pb-20 pt-48">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-brand-300">
            Recycling Logistics · Northern &amp; Central California
          </p>
          <h1 class="mt-5 text-5xl font-bold tracking-tight text-white leading-none md:text-6xl max-w-2xl">
            Our Services
          </h1>
          <p class="mt-6 max-w-xl text-xl text-brand-200 leading-relaxed">
            We handle the logistics — transportation, compliance, and finding the right buyers and recyclers — to get maximum value from your end-of-life and surplus material.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── Service Categories ────────────────────────────────────────────── -->
    {services.map((service) => (
      <section
        id={service.id}
        class:list={[
          'py-24 lg:py-32',
          service.dark ? 'bg-brand-900' : '',
        ]}
      >
        <div class="section-container">

          <!-- Category header + image -->
          <div class:list={[
            'grid gap-16 mb-16',
            service.image ? 'lg:grid-cols-2 lg:items-center' : '',
          ]}>
            <div>
              <p class:list={[
                'text-xs font-bold uppercase tracking-[0.2em]',
                service.dark ? 'text-brand-400' : 'text-brand-500',
              ]}>{service.eyebrow}</p>
              <h2 class:list={[
                'mt-3 text-4xl font-bold leading-tight',
                service.dark ? 'text-white' : 'text-gray-900',
              ]}>{service.title}</h2>
              <div class:list={[
                'mt-3 h-1 w-10',
                service.dark ? 'bg-brand-500' : 'bg-brand-600',
              ]}></div>
              <p class:list={[
                'mt-6 text-lg leading-relaxed max-w-xl',
                service.dark ? 'text-brand-300' : 'text-gray-600',
              ]}>{service.description}</p>
              {service.href && (
                <a
                  href={service.href}
                  class:list={[
                    'mt-6 inline-flex items-center gap-1.5 text-sm font-semibold no-underline transition-colors',
                    service.dark ? 'text-brand-400 hover:text-brand-200' : 'text-brand-600 hover:text-brand-800',
                  ]}
                >
                  View Full Details
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              )}
            </div>
            {service.image && (
              <div class="overflow-hidden">
                <img
                  src={service.image}
                  alt={service.imageAlt}
                  class="w-full h-72 object-cover"
                  loading="lazy"
                />
              </div>
            )}
          </div>

          <!-- Sub-service cards -->
          {service.dark ? (
            <div class="grid gap-px bg-brand-700 sm:grid-cols-2 lg:grid-cols-3">
              {service.subservices.map((sub) => (
                <div class="bg-brand-800 hover:bg-brand-700/80 transition-colors p-8 flex flex-col">
                  {sub.image && (
                    <div class="overflow-hidden mb-6 -mx-8 -mt-8">
                      <img src={sub.image} alt={sub.imageAlt} class="w-full h-40 object-cover" loading="lazy" />
                    </div>
                  )}
                  <h3 class="text-base font-bold text-white">{sub.title}</h3>
                  <p class="mt-3 text-sm text-brand-300 leading-relaxed flex-1">{sub.description}</p>
                </div>
              ))}
            </div>
          ) : (
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {service.subservices.map((sub) => (
                <div class="service-card overflow-hidden">
                  {sub.image && (
                    <div class="-mx-8 -mt-8 mb-6">
                      <img src={sub.image} alt={sub.imageAlt} class="w-full h-40 object-cover" loading="lazy" />
                    </div>
                  )}
                  <h3 class="text-base font-bold text-gray-900">{sub.title}</h3>
                  <p class="mt-3 text-sm text-gray-600 leading-relaxed">{sub.description}</p>
                  {sub.href && (
                    <a href={sub.href} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 no-underline hover:text-brand-800 transition-colors">
                      Learn More
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                      </svg>
                    </a>
                  )}
                </div>
              ))}
            </div>
          )}

        </div>
      </section>
    ))}

    <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
    <section class="bg-brand-800 py-20">
      <div class="section-container">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="text-3xl font-bold text-white lg:text-4xl">Have a Project in Mind?</h2>
            <p class="mt-3 text-lg text-brand-200">
              Contact us for a consultation and custom quote for your recycling and logistics needs.
            </p>
          </div>
          <div class="flex-shrink-0">
            <a href="/contact" class="btn-white px-8 py-4 text-sm">Get In Touch</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
