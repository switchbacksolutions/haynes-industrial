---
import BaseLayout from '@/layouts/BaseLayout.astro';

const projectTypes = [
  'Universal Waste Management',
  'E-Waste / Electronics Recycling',
  'Battery Recycling',
  'HVAC & Appliance Recycling',
  'Medical & Lab Equipment Disposal',
  'Lightbulb & Lamp Recycling',
  'Industrial Resale',
  'Demolition Services',
  'Industrial Cleaning',
  'Other',
];

const inputClass = 'mt-1.5 block w-full border border-gray-300 bg-white px-4 py-3 text-gray-900 placeholder-gray-400 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 text-sm';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Haynes Industrial — we'd love to hear about your recycling and waste management project."
>
  <main>

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section class="bg-brand-900 py-24">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.25em] text-brand-400">Get In Touch</p>
        <h1 class="mt-4 text-5xl font-bold text-white leading-none md:text-6xl">
          Contact Us
        </h1>
        <div class="mt-4 h-1 w-10 bg-brand-500"></div>
        <p class="mt-6 max-w-xl text-xl text-brand-200 leading-relaxed">
          We'd love to hear from you. Whether you have questions, need a quote, or want to discuss how we can help your project, reach out any way that's most convenient for you.
        </p>
      </div>
    </section>

    <!-- ─── Contact section ───────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <div class="grid gap-16 lg:grid-cols-3">

          <!-- Contact info -->
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Reach Us Directly</p>
            <h2 class="mt-3 text-3xl font-bold text-gray-900 leading-tight">Let's Talk</h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>

            <div class="mt-10 space-y-8">

              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 flex h-10 w-10 items-center justify-center bg-brand-600" aria-hidden="true">
                  <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-gray-500">Email</p>
                  <a href="mailto:jon@haynesindustrial.com" class="mt-1 block text-base font-medium text-brand-600 no-underline hover:underline">
                    jon@haynesindustrial.com
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 flex h-10 w-10 items-center justify-center bg-brand-600" aria-hidden="true">
                  <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-gray-500">Phone</p>
                  <a href="tel:9166729417" class="mt-1 block text-base font-medium text-brand-600 no-underline hover:underline">
                    916-672-9417
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 flex h-10 w-10 items-center justify-center bg-brand-600" aria-hidden="true">
                  <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-gray-500">Service Area</p>
                  <p class="mt-1 text-base text-gray-700">Northern &amp; Central California</p>
                </div>
              </div>

            </div>

            <!-- Credential strip -->
            <div class="mt-12 border-t border-gray-200 pt-8 space-y-2">
              <p class="text-xs font-bold uppercase tracking-widest text-brand-600">Licensed · Bonded · Insured</p>
              <p class="text-xs text-gray-500">C-21 Licensed Demolition Contractor</p>
            </div>
          </div>

          <!-- Form -->
          <div class="lg:col-span-2">
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="space-y-6"
            >
              <p class="hidden">
                <label>Don't fill this out: <input name="bot-field" /></label>
              </p>

              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <label for="first-name" class="block text-xs font-bold uppercase tracking-wider text-gray-700">
                    First Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="first-name"
                    name="first-name"
                    required
                    autocomplete="given-name"
                    class={inputClass}
                    placeholder="Jane"
                  />
                </div>
                <div>
                  <label for="last-name" class="block text-xs font-bold uppercase tracking-wider text-gray-700">
                    Last Name
                  </label>
                  <input
                    type="text"
                    id="last-name"
                    name="last-name"
                    autocomplete="family-name"
                    class={inputClass}
                    placeholder="Smith"
                  />
                </div>
              </div>

              <div class="grid gap-6 sm:grid-cols-2">
                <div>
                  <label for="email" class="block text-xs font-bold uppercase tracking-wider text-gray-700">
                    Email <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    class={inputClass}
                    placeholder="jane@example.com"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-gray-700">
                    Phone <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    autocomplete="tel"
                    class={inputClass}
                    placeholder="(555) 000-0000"
                  />
                </div>
              </div>

              <div>
                <label for="project-type" class="block text-xs font-bold uppercase tracking-wider text-gray-700">
                  Project Type <span class="text-red-500">*</span>
                </label>
                <select
                  id="project-type"
                  name="project-type"
                  required
                  class={inputClass}
                >
                  <option value="" disabled selected>Select a service…</option>
                  {projectTypes.map((type) => (
                    <option value={type}>{type}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="message" class="block text-xs font-bold uppercase tracking-wider text-gray-700">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  class={inputClass}
                  placeholder="Tell us about your project…"
                ></textarea>
              </div>

              <div>
                <button type="submit" class="btn-primary px-8 py-4 text-sm">
                  Send Message
                </button>
              </div>
            </form>
          </div>

        </div>
      </div>
    </section>

  </main>
</BaseLayout>
