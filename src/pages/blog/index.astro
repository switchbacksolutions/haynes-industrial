---
/**
 * src/pages/blog/index.astro — Blog listing page
 *
 * Displays all published blog posts sorted by publication date (newest first).
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect all unique tags across published posts
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog"
  description="Articles, tutorials, and notes on web development, Astro, and more."
>
  <main class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <!-- Page header -->
    <header class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white">Blog</h1>
      <p class="mt-3 text-lg text-gray-600 dark:text-gray-400">
        {posts.length} post{posts.length !== 1 ? 's' : ''} published
      </p>

      <!-- Tag filter links -->
      {allTags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {allTags.map((tag) => (
            <span class="tag-pill cursor-default">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Post list -->
    {posts.length === 0 ? (
      <p class="text-gray-500 dark:text-gray-400">
        No posts yet — check back soon!
      </p>
    ) : (
      <ul class="divide-y divide-gray-200 dark:divide-gray-700 list-none m-0 p-0" data-testid="blog-post-list">
        {posts.map((post) => (
          <li class="py-8 first:pt-0">
            <article class="group flex gap-6">
              <!-- Hero thumbnail -->
              {post.data.heroImage && (
                <a
                  href={`/blog/${post.slug}`}
                  class="hidden sm:block flex-shrink-0"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <img
                    src={post.data.heroImage}
                    alt=""
                    class="h-28 w-44 rounded-lg object-cover"
                    loading="lazy"
                    width={352}
                    height={224}
                  />
                </a>
              )}

              <div class="flex-1 min-w-0">
                <!-- Tags -->
                {post.data.tags.length > 0 && (
                  <div class="mb-2 flex flex-wrap gap-1">
                    {post.data.tags.map((tag) => (
                      <span class="tag-pill">{tag}</span>
                    ))}
                  </div>
                )}

                <!-- Title -->
                <h2 class="text-xl font-semibold">
                  <a
                    href={`/blog/${post.slug}`}
                    class="text-gray-900 no-underline hover:text-brand-600 dark:text-white dark:hover:text-brand-400 transition-colors"
                  >
                    {post.data.title}
                  </a>
                </h2>

                <!-- Description -->
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
                  {post.data.description}
                </p>

                <!-- Metadata -->
                <div class="mt-3 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                  <FormattedDate date={post.data.pubDate} format="long" />
                  {post.data.updatedDate && post.data.updatedDate > post.data.pubDate && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>
                        Updated <FormattedDate date={post.data.updatedDate} format="short" />
                      </span>
                    </>
                  )}
                </div>
              </div>
            </article>
          </li>
        ))}
      </ul>
    )}
  </main>
</BaseLayout>
