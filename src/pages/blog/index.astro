---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog"
  description="Articles, tutorials, and notes on web development, Astro, and more."
>
  <main>

    <!-- ─── Header ───────────────────────────────────────────────────────── -->
    <section class="bg-brand-900 py-24">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.25em] text-brand-400">Insights &amp; Updates</p>
        <h1 class="mt-4 text-5xl font-bold text-white leading-none md:text-6xl">Blog</h1>
        <div class="mt-4 h-1 w-10 bg-brand-500"></div>
        <p class="mt-6 text-lg text-brand-300">
          {posts.length} post{posts.length !== 1 ? 's' : ''} published
        </p>

        {allTags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {allTags.map((tag) => (
              <span class="tag-pill cursor-default">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- ─── Post list ─────────────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        {posts.length === 0 ? (
          <p class="text-gray-500">No posts yet — check back soon!</p>
        ) : (
          <ul class="divide-y divide-gray-200 list-none m-0 p-0" data-testid="blog-post-list">
            {posts.map((post) => (
              <li class="py-10 first:pt-0">
                <article class="group flex gap-8">

                  {post.data.heroImage && (
                    <a
                      href={`/blog/${post.id}`}
                      class="hidden sm:block flex-shrink-0"
                      tabindex="-1"
                      aria-hidden="true"
                    >
                      <img
                        src={post.data.heroImage}
                        alt=""
                        class="h-32 w-52 object-cover"
                        loading="lazy"
                        width={416}
                        height={256}
                      />
                    </a>
                  )}

                  <div class="flex-1 min-w-0">
                    {post.data.tags.length > 0 && (
                      <div class="mb-3 flex flex-wrap gap-1.5">
                        {post.data.tags.map((tag) => (
                          <span class="tag-pill">{tag}</span>
                        ))}
                      </div>
                    )}

                    <h2 class="text-2xl font-bold">
                      <a
                        href={`/blog/${post.id}`}
                        class="text-gray-900 no-underline hover:text-brand-600 transition-colors"
                      >
                        {post.data.title}
                      </a>
                    </h2>

                    <p class="mt-3 text-base text-gray-600 leading-relaxed line-clamp-2">
                      {post.data.description}
                    </p>

                    <div class="mt-4 flex items-center gap-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
                      <FormattedDate date={post.data.pubDate} format="long" />
                      {post.data.updatedDate && post.data.updatedDate > post.data.pubDate && (
                        <>
                          <span aria-hidden="true">·</span>
                          <span>Updated <FormattedDate date={post.data.updatedDate} format="short" /></span>
                        </>
                      )}
                    </div>
                  </div>

                </article>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

  </main>
</BaseLayout>
