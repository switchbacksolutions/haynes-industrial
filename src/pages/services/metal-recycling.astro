---
import BaseLayout from '@/layouts/BaseLayout.astro';

const trades = [
  { name: 'Plumbers', materials: 'Copper and steel piping from renovation and installation jobs' },
  { name: 'HVAC Installers', materials: 'Refrigerant recovery (EPA 608), unit removal, copper line sets, condenser coils' },
  { name: 'Electricians', materials: 'Insulated wire, conduit, panel copper' },
  { name: 'Solar Installers', materials: 'Aluminum racking, copper wiring, end-of-life panels' },
  { name: 'Telecom Contractors', materials: 'Copper cabling, aluminum enclosures' },
  { name: 'Sign Installers & CNC Shops', materials: 'Aluminum sheet offcuts, non-ferrous metals' },
  { name: 'Warehouses & Fleets', materials: 'Forklift batteries, industrial steel' },
  { name: 'General Industrial', materials: 'Mixed loads, demolition metal' },
];

const materialCategories = [
  {
    category: 'Ferrous',
    items: ['Steel piping', 'Structural steel', 'Rebar', 'Sheet steel'],
  },
  {
    category: 'Non-Ferrous',
    items: ['Copper — bare bright, #1, #2', 'Aluminum — sheet, extrusion, cast', 'Brass', 'Lead', 'Stainless steel'],
  },
  {
    category: 'Specialty',
    items: ['Refrigerant recovery units (EPA 608)', 'Appliances with refrigerant still charged — we recover on-site (EPA 608 licensed)', 'Forklift & industrial batteries', 'Electric motors', 'Transformers', 'Copper wiring — insulated and bare'],
  },
];

const differentiators = [
  'We pick up at your job site — no hauling, no lost half-days at a drop-off yard',
  'Industrial scale: full truckloads and ongoing contractor account relationships',
  'EPA 608 certified for refrigerant recovery — most recycling yards aren\'t',
  'Pricing tied to current commodity spot rates, explained before we load — no surprises',
  'Sacramento regional focus — real local relationships, same-week scheduling',
];

const faqs = [
  {
    q: 'How fast can you come?',
    a: 'Same-week pickup in most cases throughout the Sacramento region. Call or email — we schedule within one business day and confirm your window before the truck rolls.',
  },
  {
    q: 'Is there a minimum load?',
    a: 'No fixed weight minimum, but the load needs to be worth the trip — a full truck bed, a half-pallet of copper, or equivalent bulk. Not sure? Send us a photo and we\'ll give you a straight answer.',
  },
  {
    q: 'Do I need to sort the material?',
    a: 'No. We take mixed loads. That said, separated copper and aluminum commands better rates because it grades directly to market. If you have the time, sorting pays — we\'ll tell you which metals are worth separating.',
  },
  {
    q: 'How do you price?',
    a: 'We price against current commodity spot rates — not an opaque "yard price" we make up on the spot. You\'ll know the per-pound rate for your material category when we schedule, confirmed on-site before we load.',
  },
];
---

<BaseLayout
  title="Metal Recycling | Haynes Industrial"
  description="Industrial metal recycling pickup for licensed contractors throughout Northern California. Copper, aluminum, steel and more — we come to your job site. Same-week scheduling in the Sacramento region."
>
  <main>

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section class="relative isolate overflow-hidden min-h-[70vh] flex items-end">
      <img
        src="/images/loaded-truck-pipe.avif"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
        fetchpriority="high"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-900/80 to-brand-900/20"></div>
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-brand-900/95 via-brand-900/40 to-transparent"></div>
      <div class="w-full">
        <div class="section-container pb-20 pt-48">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-brand-300">
            Metal Recycling · Sacramento Region
          </p>
          <h1 class="mt-5 text-5xl font-bold tracking-tight text-white leading-none text-balance md:text-6xl max-w-2xl">
            We Come to Your Job Site. You Don't Haul — You Get Paid.
          </h1>
          <p class="mt-8 max-w-xl text-xl text-brand-200 leading-relaxed">
            Industrial metal recycling pickup for licensed contractors throughout Northern California. Same-week scheduling. Market-rate pricing. No lost half-days at the yard.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary px-7 py-3.5 text-sm">Schedule a Pickup</a>
            <a href="#materials" class="btn-outline-white px-7 py-3.5 text-sm">See What We Accept</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Who We Work With ──────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Serving Licensed Contractors</p>
        <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Who We Work With</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <p class="mt-6 max-w-2xl text-lg text-gray-600 leading-relaxed">
          If metal recycling is part of your work, we're the pickup call you should already have in your contacts. We serve licensed contractors and industrial operators across Northern and Central California.
        </p>
        <div class="mt-12 grid gap-px bg-gray-200 sm:grid-cols-2 lg:grid-cols-4">
          {trades.map((trade) => (
            <div class="bg-white p-6">
              <h3 class="text-sm font-bold text-brand-700">{trade.name}</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">{trade.materials}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Field Photo ─────────────────────────────────────────────────── -->
    <section class="py-20">
      <div class="section-container">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div class="overflow-hidden">
            <img
              src="/images/worker-loading-trailer.avif"
              alt="Haynes Industrial worker in an orange shirt standing in a dump trailer loaded with copper wire"
              class="w-full aspect-square object-cover object-center"
              loading="lazy"
            />
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">In the Field</p>
            <p class="mt-4 text-2xl font-semibold text-gray-800 leading-snug">
              We show up with the truck and do the loading — your crew stays on the job.
            </p>
            <p class="mt-4 text-base text-gray-600 leading-relaxed">
              Pricing tied to current commodity spot rates, explained before we load. No surprises.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── What We Accept ────────────────────────────────────────────────── -->
    <section id="materials" class="bg-gray-50 py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Material Reference</p>
        <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">What We Accept</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <p class="mt-6 text-lg text-gray-600">
          Reference for foremen and site leads. If you're unsure about a specific item, call us — we'll tell you straight.
        </p>

        <div class="mt-12 grid gap-6 lg:grid-cols-3">
          {materialCategories.map((cat) => (
            <div class="service-card">
              <h3 class="text-lg font-bold text-gray-900">{cat.category}</h3>
              <ul class="mt-5 space-y-3">
                {cat.items.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-gray-600">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 bg-brand-500" aria-hidden="true"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="mt-6 border-l-4 border-brand-500 bg-brand-50 p-6">
          <p class="text-sm text-brand-800">
            <span class="font-bold">Not sure if we take it?</span> Call us — we'll give you a straight answer. <a href="tel:9166729417" class="font-semibold underline hover:text-brand-600">916-672-9417</a>
          </p>
        </div>
      </div>
    </section>

    <!-- ─── Why Haynes Industrial ─────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Industrial Scale</p>
            <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Industrial Pickup. Industrial Scale. Industrial Pricing.</h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              We're not a consumer drop-off yard. We handle full truckloads, run ongoing contractor accounts, and price at rates tied to the actual commodity market — not whatever feels right that day.
            </p>
            <ul class="mt-8 space-y-0 list-none m-0 p-0 divide-y divide-gray-100">
              {differentiators.map((item) => (
                <li class="flex items-start gap-4 py-5">
                  <span class="mt-0.5 flex-shrink-0 h-5 w-5 bg-brand-600 flex items-center justify-center" aria-hidden="true">
                    <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-base text-gray-700 leading-snug">{item}</span>
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn-primary mt-10 inline-flex px-7 py-3.5 text-sm">Get a Quote</a>
          </div>
          <div class="overflow-hidden">
            <img
              src="/images/copper-bin-metal.avif"
              alt="Overhead view of a bin overflowing with bare bright copper wire coils"
              class="w-full h-96 object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ─── One-Time vs Recurring ─────────────────────────────────────────── -->
    <section class="bg-brand-900 py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400">Flexible Arrangements</p>
        <h2 class="mt-3 text-4xl font-bold text-white leading-tight">One-Time Pickup or Ongoing Account?</h2>
        <div class="mt-3 h-1 w-10 bg-brand-500"></div>
        <div class="mt-14 grid gap-px bg-brand-700 lg:grid-cols-2">

          <div class="bg-brand-800 p-10">
            <div class="mb-5 flex h-12 w-12 items-center justify-center bg-brand-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white">One-Time Pickup</h3>
            <p class="mt-4 text-brand-200 leading-relaxed">
              Wrapping up a demo job, clearing a warehouse, or moving locations? We handle single-load pickups — one call, one truck, one check. Ideal for large accumulated loads or project closeout cleanups.
            </p>
            <ul class="mt-6 space-y-3">
              {['Schedule within the week', 'We load and haul — your crew stays productive', 'Payment at pickup or by invoice'].map((item) => (
                <li class="flex items-center gap-3 text-sm text-brand-200">
                  <span class="h-1.5 w-1.5 flex-shrink-0 bg-brand-400" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn-white mt-8 inline-flex px-7 py-3 text-sm">Schedule a Pickup</a>
          </div>

          <div class="bg-brand-800 p-10">
            <div class="mb-5 flex h-12 w-12 items-center justify-center bg-brand-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white">Recurring Account</h3>
            <p class="mt-4 text-brand-200 leading-relaxed">
              If you generate metal regularly — weekly, monthly, or job-by-job — we set up an ongoing arrangement. You call when you're ready, we come. No renegotiating rates every visit, no new-vendor hassle each time.
            </p>
            <ul class="mt-6 space-y-3">
              {['Priority scheduling for active accounts', 'Consistent pricing tied to market rates', 'One local contact who knows your site and materials'].map((item) => (
                <li class="flex items-center gap-3 text-sm text-brand-200">
                  <span class="h-1.5 w-1.5 flex-shrink-0 bg-brand-400" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn-white mt-8 inline-flex px-7 py-3 text-sm">Set Up an Account</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── FAQ ───────────────────────────────────────────────────────────── -->
    <section class="bg-gray-50 py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Straight Answers</p>
        <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Common Questions</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <div class="mt-12 grid gap-6 lg:grid-cols-2">
          {faqs.map((faq) => (
            <div class="card">
              <h3 class="text-base font-bold text-gray-900">{faq.q}</h3>
              <p class="mt-3 text-sm text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
    <section class="bg-brand-800 py-20">
      <div class="section-container">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="text-3xl font-bold text-white lg:text-4xl">Turn End-of-Job Metal Into a Check</h2>
            <p class="mt-3 text-lg text-brand-200">
              Call us or send a message — we'll schedule a pickup and let you get back to work.
            </p>
          </div>
          <div class="flex flex-shrink-0 flex-wrap gap-4">
            <a href="/contact" class="btn-white px-7 py-3.5 text-sm">Schedule a Pickup</a>
            <a href="tel:9166729417" class="btn-outline-white px-7 py-3.5 text-sm">916-672-9417</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
