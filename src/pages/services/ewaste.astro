---
import BaseLayout from '@/layouts/BaseLayout.astro';

const customers = [
  {
    name: 'Computer & Cell Phone Repair Shops',
    detail: 'Gold-bearing CPUs, RAM fingers, motherboards, accumulated broken handsets, batteries, screens, and parts inventory — we take the whole pile.',
  },
  {
    name: 'IT Departments & ITAD Providers',
    detail: 'Decommissioned servers, workstations, laptops, and networking gear with full documentation and certificates of destruction for every storage device.',
  },
  {
    name: 'Environmental Compliance Companies',
    detail: 'A certified downstream partner you can refer your own clients to without taking on liability. We produce the documentation your clients need.',
  },
  {
    name: 'Property Managers & Office Buildings',
    detail: 'Tenant move-outs and end-of-lease equipment cleanouts. One call covers everything left behind — no sorting required on your end.',
  },
  {
    name: 'Schools & Municipalities',
    detail: 'Bulk equipment refresh cycles. We handle the volume, provide itemized receipts, and keep your disposal records clean for audit purposes.',
  },
  {
    name: 'Healthcare Organizations',
    detail: 'End-of-life clinical workstations, diagnostic equipment, and administrative hardware — handled with the documentation healthcare requires.',
  },
];

const materialCategories = [
  {
    category: 'Computing',
    items: [
      'Desktop and tower computers',
      'Laptops and notebooks',
      'Servers and workstations',
      'Monitors — LCD and CRT',
      'All-in-one computers',
    ],
  },
  {
    category: 'Components & PCBs',
    items: [
      'Motherboards',
      'CPUs (gold-bearing)',
      'RAM — including gold-finger RAM strips',
      'GPUs and graphics cards',
      'Hard drives (HDD and SSD)',
      'Power supplies',
      'Network cards and expansion cards',
      'Telecom boards and gold-bearing material',
    ],
  },
  {
    category: 'Mobile & Batteries',
    items: [
      'Smartphones (all carriers)',
      'Tablets and e-readers',
      'Li-ion and Li-poly battery packs',
      'Backup battery banks',
    ],
  },
  {
    category: 'Networking & Infrastructure',
    items: [
      'Routers and managed switches',
      'UPS battery backup units',
      'Patch panels and cabling',
      'PDUs (power distribution units)',
      'Rack enclosures',
    ],
  },
  {
    category: 'Peripherals & Office',
    items: [
      'Keyboards and mice',
      'Printers (toner cartridges removed)',
      'Scanners and fax machines',
      'Docking stations and hubs',
      'VoIP phones and desk phones',
    ],
  },
  {
    category: 'Specialty & Gold-Bearing',
    items: [
      'Gold-bearing CPU pins and RAM fingers',
      'Telecom switch cards',
      'High-density server blade chassis',
      'Industrial control boards',
    ],
  },
];

const differentiators = [
  'One outlet for everything — we take the full mix, not just the easy stuff',
  'Sacramento-area pickup — no shipping your equipment to an unknown facility',
  'We pay for material with value: gold-bearing components, working units suitable for refurbishment',
  'Certificates of destruction issued for every storage device — hard drives, SSDs, flash media',
  'Bonded, insured, with real documentation for every transaction',
  'CEW registered (Cal Recycle / DTSC) — we legally accept e-waste and produce the compliance records you need',
];

const faqs = [
  {
    q: 'How is data destroyed?',
    a: 'We offer two options: physical shredding or certified multi-pass wipe (NIST SP 800-88 compliant). Both result in a certificate of destruction issued to you, listing each device by serial number. Physical shredding is appropriate for drives that have held particularly sensitive data — the platters are rendered physically unreadable. Wipe-and-certify is appropriate for most business IT refresh cycles.',
  },
  {
    q: 'What documentation do I receive?',
    a: 'You get a serialized intake receipt at pickup listing every item we took, and a certificate of data destruction for each storage device. If you need downstream documentation — the name and location of the recycling facility your material went to — we can provide that as well. Environmental compliance customers often need this for client reporting.',
  },
  {
    q: 'What about hard drives specifically?',
    a: 'Every hard drive and SSD is logged by serial number at intake. You choose shred or wipe. Either way, nothing leaves our custody without a destruction record. We don\'t sell used drives with data intact — ever.',
  },
  {
    q: 'Do you take CRT monitors?',
    a: 'Yes. CRT monitors contain lead-bearing glass and require regulated handling — most recyclers turn them away or charge a premium. We accept them as part of a full load. Call ahead if you have a large volume of CRTs so we can plan appropriately.',
  },
  {
    q: 'Do I get paid for my equipment?',
    a: 'It depends on what you have. Gold-bearing components — high-density RAM, certain CPU families, telecom boards — have real commodity value and we pay for them. Working units suitable for refurbishment also have value. Equipment that\'s end-of-life with no recovery value we take at no charge. We\'ll give you a straight answer on the phone before scheduling.',
  },
  {
    q: 'Is there a minimum load?',
    a: 'No hard minimum, but the load should be worth the trip — a pallet of gear, a rack of servers, or equivalent bulk. Send us a photo or a rough item list and we\'ll tell you straight.',
  },
];
---

<BaseLayout
  title="E-Waste / Electronics Recycling | Haynes Industrial"
  description="Certified e-waste recycling pickup for businesses in Sacramento and Northern California. Data destruction certificates, chain-of-custody documentation, and buy-back for gold-bearing components."
>
  <main>

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section class="relative isolate overflow-hidden min-h-[70vh] flex items-end">
      <img
        src="/images/computer-components-ewaste.jpeg"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
        fetchpriority="high"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-900/80 to-brand-900/20"></div>
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-brand-900/95 via-brand-900/40 to-transparent"></div>
      <div class="w-full">
        <div class="section-container pb-20 pt-48">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-brand-300">
            E-Waste Recycling · Sacramento Region
          </p>
          <h1 class="mt-5 text-5xl font-bold tracking-tight text-white leading-none text-balance md:text-6xl max-w-2xl">
            Bulk Pick-up. Certified Destruction.
          </h1>
          <p class="mt-8 max-w-xl text-xl text-brand-200 leading-relaxed">
            One place for everything you've got piling up — computers, servers, networking gear, phones, and gold-bearing components. We come to you with the paperwork your compliance team needs.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary px-7 py-3.5 text-sm">Schedule a Pickup</a>
            <a href="#compliance" class="btn-outline-white px-7 py-3.5 text-sm">Compliance &amp; Documentation</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Who We Work With ──────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Our Clients</p>
        <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Who We Work With</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <p class="mt-6 max-w-2xl text-lg text-gray-600 leading-relaxed">
          We serve businesses that generate end-of-life electronics and need a partner they can hand off to — and trust will do the right thing downstream.
        </p>
        <div class="mt-12 grid gap-px bg-gray-200 sm:grid-cols-2 lg:grid-cols-3">
          {customers.map((customer) => (
            <div class="bg-white p-8">
              <h3 class="text-sm font-bold text-brand-700">{customer.name}</h3>
              <p class="mt-3 text-sm text-gray-600 leading-relaxed">{customer.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Compliance & Documentation ───────────────────────────────────── -->
    <section id="compliance" class="bg-brand-900 py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400">Data Security &amp; Documentation</p>
        <h2 class="mt-3 text-4xl font-bold text-white leading-tight">Compliance Is the Buying Decision</h2>
        <div class="mt-3 h-1 w-10 bg-brand-500"></div>
        <p class="mt-6 max-w-2xl text-lg text-brand-300 leading-relaxed">
          Your clients ask you how their data was destroyed. Your auditors ask where the equipment went. We give you the paper trail to answer both.
        </p>

        <div class="mt-14 grid gap-px bg-brand-700 lg:grid-cols-3">

          <div class="bg-brand-800 p-10">
            <div class="mb-5 flex h-12 w-12 items-center justify-center bg-brand-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white">Data Destruction</h3>
            <p class="mt-4 text-brand-200 leading-relaxed text-sm">
              Every storage device — hard drives, SSDs, flash media — is logged by serial number at intake. You choose physical shredding or certified multi-pass wipe (NIST SP 800-88 compliant). Either way, you receive a certificate of data destruction listing each device.
            </p>
          </div>

          <div class="bg-brand-800 p-10">
            <div class="mb-5 flex h-12 w-12 items-center justify-center bg-brand-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white">Chain of Custody</h3>
            <p class="mt-4 text-brand-200 leading-relaxed text-sm">
              Serialized intake receipt at pickup lists every item we take. We document the downstream path from your facility to the recycling end point. Environmental compliance customers and ITAD providers get the downstream facility detail they need for client reporting.
            </p>
          </div>

          <div class="bg-brand-800 p-10">
            <div class="mb-5 flex h-12 w-12 items-center justify-center bg-brand-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.499z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white">Certifications</h3>
            <p class="mt-4 text-brand-200 leading-relaxed text-sm">
              CEW registered with Cal Recycle / DTSC. We operate under responsible recycling practices aligned with R2v3 and e-Stewards standards (certification in process). Bonded and insured. Real receipts, real documentation — not a handshake and a load ticket.
            </p>
          </div>

        </div>

        <div class="mt-8 border-l-4 border-brand-500 bg-brand-800/60 p-6">
          <p class="text-brand-200 text-sm leading-relaxed">
            <span class="font-bold text-white">For environmental compliance companies:</span> When you refer your clients to a downstream e-waste partner, you're vouching for them. We give you the documentation to back that referral up — chain of custody, destruction certificates, and downstream facility detail. You can refer us without exposure.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── What We Accept ────────────────────────────────────────────────── -->
    <section id="materials" class="bg-gray-50 py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Material Reference</p>
        <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">What We Accept</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <p class="mt-6 text-lg text-gray-600">
          Reference for IT managers, facilities coordinators, and repair shop owners. If you're unsure about a specific item, call us.
        </p>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {materialCategories.map((cat) => (
            <div class="service-card">
              <h3 class="text-sm font-bold text-gray-900">{cat.category}</h3>
              <ul class="mt-4 space-y-3">
                {cat.items.map((item) => (
                  <li class="flex items-start gap-3 text-sm text-gray-600">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 bg-brand-500" aria-hidden="true"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="mt-6 border-l-4 border-brand-500 bg-brand-50 p-6">
          <p class="text-sm text-brand-800">
            <span class="font-bold">Not sure if we take it?</span> Call us — we'll give you a straight answer. <a href="tel:9166729417" class="font-semibold underline hover:text-brand-600">916-672-9417</a>
          </p>
        </div>
      </div>
    </section>

    <!-- ─── IT Departments & Repair Shops ─────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-start">

          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">For IT Departments &amp; ITAD Providers</p>
            <h2 class="mt-3 text-3xl font-bold text-gray-900 leading-tight">Data Security and Serialized Asset Tracking</h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              Your risk doesn't end when equipment leaves the building — it ends when you have documentation that the data is gone. We close that loop.
            </p>
            <ul class="mt-8 space-y-0 list-none m-0 p-0 divide-y divide-gray-100">
              {[
                'Every storage device logged by make, model, and serial number at intake',
                'Shred or certified multi-pass wipe — your choice per device',
                'Certificate of data destruction issued per device, not per batch',
                'Downstream facility documentation available for client audit files',
                'Scheduled pickups for regular refresh cycles — one account contact, no rescheduling friction',
              ].map((item) => (
                <li class="flex items-start gap-4 py-4">
                  <span class="mt-0.5 flex-shrink-0 h-5 w-5 bg-brand-600 flex items-center justify-center" aria-hidden="true">
                    <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-sm text-gray-700 leading-snug">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">For Computer &amp; Phone Repair Shops</p>
            <h2 class="mt-3 text-3xl font-bold text-gray-900 leading-tight">Get Paid for the Gold-Bearing Material</h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              Repair shops accumulate a strange mix — working parts, broken units, stripped motherboards, piles of RAM, batteries from a hundred different handsets. We take all of it, and we pay for the parts that have commodity value.
            </p>
            <ul class="mt-8 space-y-0 list-none m-0 p-0 divide-y divide-gray-100">
              {[
                'We buy gold-bearing material: CPU pins, RAM finger strips, telecom boards at commodity rates',
                'Working units suitable for refurbishment — we assess and pay for these separately',
                'Everything else we haul for free — you don\'t pay to dispose of end-of-life material',
                'We take the whole pile: no cherry-picking your inventory and leaving the rest',
                'Sacramento pickup — no boxing and shipping to an unknown buyer',
              ].map((item) => (
                <li class="flex items-start gap-4 py-4">
                  <span class="mt-0.5 flex-shrink-0 h-5 w-5 bg-brand-600 flex items-center justify-center" aria-hidden="true">
                    <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-sm text-gray-700 leading-snug">{item}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── Why Haynes ─────────────────────────────────────────────────────── -->
    <section class="bg-gray-50 py-24 lg:py-32">
      <div class="section-container">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
          <div class="overflow-hidden">
            <img
              src="/images/motherboards-ewaste.jpeg"
              alt="Computer motherboards and PCBs of various sizes arranged for recycling"
              class="w-full h-96 object-cover"
              loading="lazy"
            />
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Why Haynes Industrial</p>
            <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">One Place for Everything You've Got Piling Up</h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              Most recyclers take the easy material and leave the complicated stuff. We built this service specifically for businesses that accumulate mixed loads — and need one call to clear all of it.
            </p>
            <ul class="mt-8 space-y-0 list-none m-0 p-0 divide-y divide-gray-100">
              {differentiators.map((item) => (
                <li class="flex items-start gap-4 py-4">
                  <span class="mt-0.5 flex-shrink-0 h-5 w-5 bg-brand-600 flex items-center justify-center" aria-hidden="true">
                    <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-base text-gray-700 leading-snug">{item}</span>
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn-primary mt-10 inline-flex px-7 py-3.5 text-sm">Schedule a Pickup</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FAQ ───────────────────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Straight Answers</p>
        <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Common Questions</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <div class="mt-12 grid gap-6 lg:grid-cols-2">
          {faqs.map((faq) => (
            <div class="card">
              <h3 class="text-base font-bold text-gray-900">{faq.q}</h3>
              <p class="mt-3 text-sm text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Case Study ───────────────────────────────────────────────────── -->
    <section class="bg-gray-50 py-20">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Case Study</p>
        <h2 class="mt-3 text-3xl font-bold text-gray-900 leading-tight max-w-2xl">35 Years of Electronics Cleared from a Food Bank Warehouse</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <p class="mt-6 max-w-2xl text-gray-600 leading-relaxed">
          A regional food bank was decommissioning a warehouse with 35 years of accumulated electronics — computers, monitors, servers, and networking gear going back to the early days of IT. They needed everything gone on short notice, with destruction documentation for their records. We cleared over 80 units in a single visit, including CRT monitors most recyclers turn away.
        </p>
        <div class="mt-8 grid gap-px bg-gray-200 sm:grid-cols-3">
          <div class="bg-white p-6">
            <p class="text-3xl font-bold text-brand-700">80+</p>
            <p class="mt-1 text-sm text-gray-500">Units removed in one visit</p>
          </div>
          <div class="bg-white p-6">
            <p class="text-3xl font-bold text-brand-700">35 yrs</p>
            <p class="mt-1 text-sm text-gray-500">Of accumulated equipment</p>
          </div>
          <div class="bg-white p-6">
            <p class="text-3xl font-bold text-brand-700">100%</p>
            <p class="mt-1 text-sm text-gray-500">Destruction certificates issued</p>
          </div>
        </div>
        <a href="/case-studies#ewaste-food-bank" class="mt-8 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 no-underline hover:text-brand-800 transition-colors">
          Read the full case study
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </section>

    <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
    <section class="bg-brand-800 py-20">
      <div class="section-container">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="text-3xl font-bold text-white lg:text-4xl">Get Covered on Every Device You Move</h2>
            <p class="mt-3 text-lg text-brand-200">
              Call us or send a message — we'll schedule a pickup and have your documentation ready.
            </p>
          </div>
          <div class="flex flex-shrink-0 flex-wrap gap-4">
            <a href="/contact" class="btn-white px-7 py-3.5 text-sm">Schedule a Pickup</a>
            <a href="tel:9166729417" class="btn-outline-white px-7 py-3.5 text-sm">916-672-9417</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
