---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="Learn about Haynes Industrial — a recycling logistics company serving industrial and commercial clients across Northern and Central California. We arrange transportation, handle compliance, and maximize the value of your end-of-life and surplus material."
>
  <main>
    <!-- Page hero -->
    <section class="bg-brand-800 dark:bg-brand-900 py-20">
      <div class="section-container text-center">
        <h1 class="text-5xl font-bold text-white">About Haynes Industrial</h1>
        <p class="mx-auto mt-6 max-w-2xl text-xl text-brand-200">
          Recycling Logistics for Industrial & Commercial Businesses
        </p>
      </div>
    </section>

    <!-- About Us -->
    <section class="py-20">
      <div class="section-container">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white">About Us</h2>
            <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
              Haynes Industrial is a recycling logistics company. Most businesses with end-of-life or surplus material face the same problem: they don't know what it's worth, which recycler or buyer handles it correctly, or how to move it without creating a compliance headache. We solve that.
            </p>
            <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
              We hold a freight brokerage license, maintain relationships with buyers and recyclers across the material spectrum, and handle compliance documentation from intake to final disposition. One call covers transportation, recycling, surplus buying, and the paperwork — so you don't have to manage multiple vendors or figure out the regulations yourself.
            </p>
          </div>
          <div class="rounded-xl overflow-hidden">
            <img
              src="/images/forklift-wire-bin.avif"
              alt="Haynes Industrial forklift moving wire bin of materials"
              class="w-full h-80 object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="py-20">
      <div class="section-container">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-10">Our Team</h2>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          <div class="card text-center">
            <img
              src="/images/project-manager-profile.avif"
              alt="Project Manager"
              class="mx-auto h-24 w-24 rounded-full object-cover"
              loading="lazy"
            />
            <h3 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">Project Manager</h3>
          </div>
          <div class="card text-center">
            <img
              src="/images/warehouse-sup-profile.avif"
              alt="Warehouse Supervisor"
              class="mx-auto h-24 w-24 rounded-full object-cover"
              loading="lazy"
            />
            <h3 class="mt-4 text-lg font-semibold text-gray-900 dark:text-white">Warehouse Supervisor</h3>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission & Vision -->
    <section class="bg-gray-50 dark:bg-gray-900 py-20">
      <div class="section-container">
        <div class="grid gap-10 lg:grid-cols-2">
          <div class="card">
            <div class="h-12 w-12 rounded-full bg-brand-100 dark:bg-brand-900 flex items-center justify-center mb-6">
              <svg class="h-6 w-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Our Mission</h2>
            <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">
              Businesses shouldn't have to figure out which recycler handles which material, navigate compliance requirements on their own, or leave money on the table because they don't know what their scrap is worth.
            </p>
            <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">
              We take on that logistics complexity — transportation, downstream relationships, compliance documentation — so our clients can focus on their core work.
            </p>
          </div>

          <div class="card">
            <div class="h-12 w-12 rounded-full bg-brand-100 dark:bg-brand-900 flex items-center justify-center mb-6">
              <svg class="h-6 w-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Our Vision</h2>
            <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">
              A future where no industrial business has to overpay for disposal, leave recyclable material in a landfill, or face a compliance violation because the logistics were too complicated to sort out. Haynes Industrial builds the infrastructure — transportation, relationships, documentation — that makes that possible.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-20">
      <div class="section-container">
        <div class="mx-auto max-w-3xl">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Why Choose Haynes Industrial</h2>
          <ul class="mt-8 space-y-4 list-none m-0 p-0">
            {[
              'Licensed freight broker — we arrange transportation from any carrier, not just our own trucks',
              'We know what your material is worth and which buyers will pay for it',
              'End-to-end compliance: EPA 608, data destruction, regulated waste documentation',
              'Licensed, bonded, and insured',
              'One partner covers transportation, recycling, surplus buying, and compliance paperwork',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-brand-600 flex items-center justify-center">
                  <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-gray-700 dark:text-gray-300">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-brand-700 dark:bg-brand-800 py-16">
      <div class="section-container text-center">
        <h2 class="text-3xl font-bold text-white">Ready to Work Together?</h2>
        <p class="mt-4 text-lg text-brand-200">
          Reach out to discuss your recycling and waste management needs.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn-white">Contact Us</a>
          <a href="/services" class="btn-outline-white">View Services</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
