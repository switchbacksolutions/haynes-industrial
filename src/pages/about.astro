---
import BaseLayout from '@/layouts/BaseLayout.astro';

const whyUs = [
  'Licensed freight broker — we arrange transportation from any carrier, not just our own trucks',
  'We know what your material is worth and which buyers will pay for it',
  'End-to-end compliance: EPA 608, data destruction, regulated waste documentation',
  'Licensed, bonded, and insured',
  'One partner covers transportation, recycling, surplus buying, and compliance paperwork',
];
---

<BaseLayout
  title="About"
  description="Learn about Haynes Industrial — a recycling logistics company serving industrial and commercial clients across Northern and Central California. We arrange transportation, handle compliance, and maximize the value of your end-of-life and surplus material."
>
  <main>

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section class="relative isolate overflow-hidden min-h-[60vh] flex items-end">
      <img
        src="/images/loaded-truck.avif"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
        fetchpriority="high"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-900/80 to-brand-900/20"></div>
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-brand-900/95 via-brand-900/40 to-transparent"></div>
      <div class="w-full">
        <div class="section-container pb-20 pt-48">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-brand-300">
            Northern &amp; Central California
          </p>
          <h1 class="mt-5 text-5xl font-bold tracking-tight text-white leading-none md:text-6xl max-w-2xl">
            About Haynes Industrial
          </h1>
          <p class="mt-6 max-w-xl text-xl text-brand-200 leading-relaxed">
            Recycling Logistics for Industrial &amp; Commercial Businesses
          </p>
        </div>
      </div>
    </section>

    <!-- ─── Who We Are ────────────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Our Story</p>
            <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Who We Are</h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <p class="mt-8 text-lg text-gray-600 leading-relaxed">
              Haynes Industrial is a recycling logistics company. Most businesses with end-of-life or surplus material face the same problem: they don't know what it's worth, which recycler or buyer handles it correctly, or how to move it without creating a compliance headache. We solve that.
            </p>
            <p class="mt-4 text-lg text-gray-600 leading-relaxed">
              We hold a freight brokerage license, maintain relationships with buyers and recyclers across the material spectrum, and handle compliance documentation from intake to final disposition. One call covers transportation, recycling, surplus buying, and the paperwork — so you don't have to manage multiple vendors or figure out the regulations yourself.
            </p>
          </div>
          <div class="relative">
            <img
              src="/images/forklift-wire-bin.avif"
              alt="Haynes Industrial forklift moving wire bin of materials"
              class="w-full h-96 object-cover"
              loading="lazy"
            />
            <div class="absolute -bottom-4 -right-4 h-20 w-20 border-b-4 border-r-4 border-brand-600 hidden lg:block" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Our Team ──────────────────────────────────────────────────────── -->
    <section class="bg-gray-50 py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Our People</p>
        <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Our Team</h2>
        <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">

          <div class="bg-white border border-gray-200 p-8">
            <img
              src="/images/project-manager-profile.avif"
              alt="Project Manager"
              class="h-20 w-20 object-cover"
              loading="lazy"
            />
            <h3 class="mt-5 text-lg font-bold text-gray-900">Project Manager</h3>
            <div class="mt-1.5 h-0.5 w-6 bg-brand-600"></div>
          </div>

          <div class="bg-white border border-gray-200 p-8">
            <img
              src="/images/warehouse-sup-profile.avif"
              alt="Warehouse Supervisor"
              class="h-20 w-20 object-cover"
              loading="lazy"
            />
            <h3 class="mt-5 text-lg font-bold text-gray-900">Warehouse Supervisor</h3>
            <div class="mt-1.5 h-0.5 w-6 bg-brand-600"></div>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── Mission & Vision ──────────────────────────────────────────────── -->
    <section class="bg-brand-900 py-24 lg:py-32">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400">What Drives Us</p>
        <h2 class="mt-3 text-4xl font-bold text-white leading-tight">Mission &amp; Vision</h2>
        <div class="mt-3 h-1 w-10 bg-brand-500"></div>
        <div class="mt-14 grid gap-px bg-brand-700 lg:grid-cols-2">

          <div class="bg-brand-800 p-10 lg:p-12">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400">Our Mission</p>
            <h3 class="mt-4 text-2xl font-bold text-white">Turning Waste Into Value</h3>
            <div class="mt-2 h-0.5 w-8 bg-brand-500"></div>
            <p class="mt-6 leading-relaxed text-brand-200">
              Businesses shouldn't have to figure out which recycler handles which material, navigate compliance requirements on their own, or leave money on the table because they don't know what their scrap is worth.
            </p>
            <p class="mt-4 leading-relaxed text-brand-200">
              We take on that logistics complexity — transportation, downstream relationships, compliance documentation — so our clients can focus on their core work.
            </p>
          </div>

          <div class="bg-brand-800 p-10 lg:p-12">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400">Our Vision</p>
            <h3 class="mt-4 text-2xl font-bold text-white">A Cleaner Industrial Economy</h3>
            <div class="mt-2 h-0.5 w-8 bg-brand-500"></div>
            <p class="mt-6 leading-relaxed text-brand-200">
              A future where no industrial business has to overpay for disposal, leave recyclable material in a landfill, or face a compliance violation because the logistics were too complicated to sort out. Haynes Industrial builds the infrastructure — transportation, relationships, documentation — that makes that possible.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── Why Choose Us ─────────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <div class="mx-auto max-w-3xl">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Our Commitment</p>
          <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">Why Choose Haynes Industrial</h2>
          <div class="mt-3 h-1 w-10 bg-brand-600"></div>
          <ul class="mt-10 space-y-0 list-none m-0 p-0 divide-y divide-gray-100">
            {whyUs.map((item) => (
              <li class="flex items-start gap-4 py-5">
                <span class="mt-0.5 flex-shrink-0 h-5 w-5 bg-brand-600 flex items-center justify-center" aria-hidden="true">
                  <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-base text-gray-700 leading-snug">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ─── CTA ───────────────────────────────────────────────────────────── -->
    <section class="bg-brand-800 py-20">
      <div class="section-container">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="text-3xl font-bold text-white lg:text-4xl">Ready to Work Together?</h2>
            <p class="mt-3 text-lg text-brand-200">
              Reach out to discuss your recycling and waste management needs.
            </p>
          </div>
          <div class="flex flex-shrink-0 flex-wrap gap-4">
            <a href="/contact" class="btn-white px-8 py-4 text-sm">Contact Us</a>
            <a href="/services" class="btn-outline-white px-8 py-4 text-sm">View Services</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
