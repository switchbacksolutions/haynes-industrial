---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Haynes Industrial"
  description="Recycling logistics for industrial and commercial businesses in Northern California. We arrange transportation, handle compliance, and find the right buyers and recyclers to maximize value from your end-of-life and surplus material."
>
  <main>
    <!-- Hero -->
    <section class="relative isolate overflow-hidden">
      <img
        src="/images/loaded-truck.avif"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 -z-10 h-full w-full object-cover object-center"
        fetchpriority="high"
      />
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-900/80 to-transparent"></div>
      <div class="section-container py-48">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-300">
          Recycling Logistics · Northern & Central California
        </p>
        <h1 class="mt-4 text-5xl font-bold tracking-tight text-white text-balance max-w-2xl">
          Your Unused Material Has Value. We Handle the Logistics.
        </h1>
        <p class="mt-6 max-w-xl text-xl text-brand-200 text-pretty">
          Haynes Industrial brokers transportation, finds the right buyers and recyclers, and manages compliance — so your end-of-life and surplus material earns money instead of costing you time.
        </p>
        <div class="mt-10 flex flex-wrap justify-start gap-4">
          <a href="/about" class="btn-primary">
            Learn More
          </a>
          <a href="/contact" class="btn-outline-white">
            Get In Touch
          </a>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="py-20">
      <div class="section-container">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white">About Us</h2>
            <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
              Haynes Industrial is a recycling logistics company. We figure out the best path for your end-of-life and surplus material — which buyers pay the most, which recyclers handle regulated material correctly, and how to move everything with the least friction.
            </p>
            <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
              We hold a freight brokerage license, so we can arrange the right carrier for every load — not just our own trucks. Add deep compliance expertise and established downstream relationships, and you get a single partner who handles the whole logistics problem.
            </p>
            <a href="/about" class="btn-primary mt-8 inline-flex">
              Learn More
            </a>
          </div>
          <div class="rounded-xl overflow-hidden">
            <img
              src="/images/loaded-truck.avif"
              alt="Haynes Industrial truck ready for pickup"
              class="w-full h-72 lg:h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Core Services -->
    <section class="bg-gray-50 dark:bg-gray-900 py-20">
      <div class="section-container">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Core Services</h2>
          <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
            Comprehensive recycling, waste management, and industrial services tailored to your needs.
          </p>
        </div>

        <div class="grid gap-8 sm:grid-cols-3">
          {[
            {
              number: '01',
              title: 'Universal Waste Management',
              image: '/images/waste-bins.avif',
              imageAlt: 'Industrial waste bins ready for collection',
              description: 'Complete solutions for universal waste — safe handling, regulatory compliance, and maximum recovery of reusable materials. Our services reduce environmental risks and make waste management seamless.',
            },
            {
              number: '02',
              title: 'Medical & Lab Equipment Disposal',
              image: '/images/lab-equipment.avif',
              imageAlt: 'Laboratory equipment staged for disposal',
              description: 'Secure, compliant disposal of medical and laboratory equipment, including decontamination, dismantling, and responsible recycling. Our processes meet regulatory requirements and ensure sensitive materials are handled with care.',
            },
            {
              number: '03',
              title: 'HVAC & Appliance Recycling',
              image: '/images/hvac.avif',
              imageAlt: 'HVAC unit ready for recycling',
              description: 'Comprehensive HVAC and appliance recycling, including certified refrigerant recovery and responsible dismantling. We ensure regulatory compliance while making end-of-life equipment management simple and efficient.',
            },
          ].map(({ number, title, image, imageAlt, description }) => (
            <div class="service-card overflow-hidden">
              <div class="-mx-8 -mt-8 mb-6">
                <img src={image} alt={imageAlt} class="w-full h-44 object-cover" loading="lazy" />
              </div>
              <p class="text-4xl font-bold text-brand-200 dark:text-brand-800">{number}</p>
              <h3 class="mt-4 text-xl font-semibold text-gray-900 dark:text-white">{title}</h3>
              <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{description}</p>
              <a href="/services" class="mt-6 inline-flex text-sm font-medium text-brand-600 no-underline hover:underline dark:text-brand-400">
                Learn More →
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-20">
      <div class="section-container">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Why Choose Haynes Industrial</h2>
            <ul class="mt-8 space-y-4 list-none m-0 p-0">
              {[
                'Licensed freight broker — we arrange transportation from any carrier, not just our own trucks',
                'We know what your material is worth and which buyers will pay for it',
                'Compliance handled end-to-end: EPA 608, data destruction, regulated waste documentation',
                'Licensed, bonded, and insured',
                'One call covers transportation, recycling, surplus buying, and compliance paperwork',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 flex-shrink-0 h-5 w-5 rounded-full bg-brand-600 flex items-center justify-center">
                    <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-gray-700 dark:text-gray-300">{item}</span>
                </li>
              ))}
            </ul>
            <a href="/services" class="btn-primary mt-10 inline-flex">
              View All Services
            </a>
          </div>
          <div class="rounded-xl bg-brand-800 p-10 text-white">
            <h3 class="text-2xl font-bold">Our Mission</h3>
            <p class="mt-4 leading-relaxed text-brand-200">
              Businesses shouldn't have to figure out which recycler handles which material, navigate compliance on their own, or leave money on the table because they don't know what their scrap is worth.
            </p>
            <p class="mt-4 leading-relaxed text-brand-200">
              We handle that — transportation, compliance, downstream relationships — from the first call to the final disposition receipt.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Carousel -->
    <section class="bg-gray-50 dark:bg-gray-900 py-20">
      <div class="section-container">
        <h2 class="text-center text-3xl font-bold text-gray-900 dark:text-white mb-12">What Clients Say</h2>
        <div class="relative mx-auto max-w-2xl" id="testimonial-carousel" aria-roledescription="carousel" aria-label="Client testimonials">
          <!-- Slides -->
          <div class="overflow-hidden">
            <div id="testimonial-track" class="flex transition-transform duration-500 ease-in-out">

              <!-- Slide 1 -->
              <div class="w-full flex-shrink-0" role="group" aria-roledescription="slide" aria-label="1 of 3">
                <div class="card text-center">
                  <img
                    src="/images/contractor-profile.avif"
                    alt="John A., General Contractor"
                    class="mx-auto h-20 w-20 rounded-full object-cover"
                    loading="lazy"
                  />
                  <svg class="mx-auto mt-6 h-8 w-8 text-brand-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                  </svg>
                  <blockquote class="mt-6 text-lg text-gray-700 dark:text-gray-300 leading-relaxed italic">
                    "Haynes Industrial is our go-to for e-waste, batteries, lightbulbs, and appliances. They make the tough jobs simple and always find a way to handle the recycling and waste removal parts smoothly."
                  </blockquote>
                  <p class="mt-6 font-semibold text-gray-900 dark:text-white">John A.</p>
                  <p class="text-sm text-gray-500 dark:text-gray-400">General Contractor</p>
                </div>
              </div>

              <!-- Slide 2 -->
              <div class="w-full flex-shrink-0" role="group" aria-roledescription="slide" aria-label="2 of 3">
                <div class="card text-center">
                  <img
                    src="/images/warehouse-sup-profile.avif"
                    alt="Brad R., Warehouse Supervisor"
                    class="mx-auto h-20 w-20 rounded-full object-cover"
                    loading="lazy"
                  />
                  <svg class="mx-auto mt-6 h-8 w-8 text-brand-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                  </svg>
                  <blockquote class="mt-6 text-lg text-gray-700 dark:text-gray-300 leading-relaxed italic">
                    "We do electrical, HVAC, and solar, and Haynes Industrial is the only company we trust with all our waste. They take care of everything from solar panels and light bulbs to old HVAC units. It's a relief to have one reliable partner who does it all."
                  </blockquote>
                  <p class="mt-6 font-semibold text-gray-900 dark:text-white">Brad R.</p>
                  <p class="text-sm text-gray-500 dark:text-gray-400">Warehouse Supervisor</p>
                </div>
              </div>

              <!-- Slide 3 -->
              <div class="w-full flex-shrink-0" role="group" aria-roledescription="slide" aria-label="3 of 3">
                <div class="card text-center">
                  <img
                    src="/images/project-manager-profile.avif"
                    alt="Jeff G., Electrical Utilities Project Manager"
                    class="mx-auto h-20 w-20 rounded-full object-cover"
                    loading="lazy"
                  />
                  <svg class="mx-auto mt-6 h-8 w-8 text-brand-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                  </svg>
                  <blockquote class="mt-6 text-lg text-gray-700 dark:text-gray-300 leading-relaxed italic">
                    "When we had to replace more than 1,200 traffic lights for a city project, Haynes Industrial stepped in and made it easy. Their recycling solutions saved us time, money, and a lot of stress."
                  </blockquote>
                  <p class="mt-6 font-semibold text-gray-900 dark:text-white">Jeff G.</p>
                  <p class="text-sm text-gray-500 dark:text-gray-400">Electrical Utilities Project Manager</p>
                </div>
              </div>

            </div>
          </div>

          <!-- Prev / Next buttons -->
          <button
            id="testimonial-prev"
            aria-label="Previous testimonial"
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-5 flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-md text-brand-700 hover:bg-brand-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-600"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </button>
          <button
            id="testimonial-next"
            aria-label="Next testimonial"
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-md text-brand-700 hover:bg-brand-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-600"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </button>

          <!-- Dot indicators -->
          <div class="mt-8 flex justify-center gap-3" role="tablist" aria-label="Testimonial slides">
            <button role="tab" aria-selected="true" aria-label="Slide 1" data-index="0" class="testimonial-dot h-2.5 w-2.5 rounded-full bg-brand-600 transition-all"></button>
            <button role="tab" aria-selected="false" aria-label="Slide 2" data-index="1" class="testimonial-dot h-2.5 w-2.5 rounded-full bg-brand-200 transition-all hover:bg-brand-400"></button>
            <button role="tab" aria-selected="false" aria-label="Slide 3" data-index="2" class="testimonial-dot h-2.5 w-2.5 rounded-full bg-brand-200 transition-all hover:bg-brand-400"></button>
          </div>
        </div>
      </div>
    </section>

    <script>
      const track = document.getElementById('testimonial-track') as HTMLElement;
      const dots = document.querySelectorAll<HTMLButtonElement>('.testimonial-dot');
      const total = 3;
      let current = 0;

      function goTo(index: number) {
        current = (index + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => {
          const active = i === current;
          d.classList.toggle('bg-brand-600', active);
          d.classList.toggle('bg-brand-200', !active);
          d.setAttribute('aria-selected', String(active));
        });
      }

      document.getElementById('testimonial-prev')?.addEventListener('click', () => goTo(current - 1));
      document.getElementById('testimonial-next')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot) => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));
    </script>

    <!-- CTA Banner -->
    <section class="bg-brand-700 dark:bg-brand-800 py-16">
      <div class="section-container text-center">
        <h2 class="text-3xl font-bold text-white">Tell Us What You Have</h2>
        <p class="mt-4 text-lg text-brand-200">
          We'll tell you what it's worth, how to move it, and how to handle any compliance requirements.
        </p>
        <a href="/contact" class="btn-white mt-8">
          Contact Us
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
