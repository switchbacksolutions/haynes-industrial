---
import BaseLayout from '@/layouts/BaseLayout.astro';

const services = [
  {
    number: '01',
    title: 'Metal Recycling',
    image: '/images/loaded-truck-pipe.avif',
    imageAlt: 'Industrial truck loaded with metal pipe for recycling',
    description: 'Pickup for licensed contractors throughout Northern California. Copper, aluminum, steel — we come to your job site, price against spot rates, and pay at pickup.',
    href: '/services/metal-recycling',
  },
  {
    number: '02',
    title: 'HVAC Recycling',
    image: '/images/hvac.avif',
    imageAlt: 'Commercial HVAC unit staged for removal and recycling',
    description: 'EPA 608 certified refrigerant recovery and unit removal for commercial HVAC equipment. We coordinate crane logistics for rooftop units. One crew handles it all in a single visit.',
    href: '/services/hvac-recycling',
  },
  {
    number: '03',
    title: 'E-Waste Recycling',
    image: '/images/wire-ewaste.avif',
    imageAlt: 'Wire and electronic waste ready for processing',
    description: 'Certified data destruction and compliant downstream handling for B2B electronics. We pay for gold-bearing material and haul the rest for free.',
    href: '/services/ewaste',
  },
  {
    number: '04',
    title: 'Industrial Surplus Buying',
    image: '/images/forklift-wire-bin.avif',
    imageAlt: 'Forklift moving industrial surplus material',
    description: 'We buy surplus equipment, chemicals, raw materials, tooling, and stranded inventory. You send a list, we assess, we pick it up, you get paid.',
    href: '/services/industrial-surplus',
  },
  {
    number: '05',
    title: 'General Logistics',
    image: '/images/haynes-industrial-truck-loaded.jpeg',
    imageAlt: 'Haynes Industrial truck loaded with material at a job site',
    description: 'Licensed transportation provider for complex, regulated, or recurring freight throughout Northern California. We source from the full carrier market.',
    href: '/services/general-logistics',
  },
];

const whyUs = [
  'Licensed transportation provider — we arrange the right carrier for every load, not just our own trucks',
  'We know what your material is worth and which buyers will pay for it',
  'Compliance handled end-to-end: EPA 608, data destruction, regulated material documentation',
  'Licensed, bonded, and insured',
  'One call covers transportation, recycling, surplus buying, and compliance paperwork',
];
---

<BaseLayout
  title="Haynes Industrial"
  description="Recycling logistics for industrial and commercial businesses in Northern California. We arrange transportation, handle compliance, and find the right buyers and recyclers to maximize value from your end-of-life and surplus material."
>
  <main>

    <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
    <section class="relative isolate overflow-hidden h-[calc(100vh-6.5rem)] flex items-end">
      <!-- Full-bleed stock photo: industrial worker cutting metal / heavy equipment -->
      <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
        <img
          src="/images/haynes-industrial-truck-closed.png"
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          style="transform: scale(1.1) translateX(6%);"
          fetchpriority="high"
        />
      </div>
      <!-- Layered gradients: heavy left + bottom pour -->
      <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-900 via-brand-900/80 to-brand-900/20"></div>
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-brand-900/95 via-brand-900/40 to-transparent"></div>

      <div class="w-full">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 pb-24 pt-48">
          <!-- Eyebrow -->
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-brand-300">
            Recycling Logistics · Northern &amp; Central California
          </p>

          <h1 class="mt-5 text-5xl font-bold tracking-tight text-white leading-none text-balance md:text-6xl lg:text-7xl max-w-3xl">
            Recycling Logistics,
            Handled Right.
          </h1>

          <p class="mt-8 max-w-xl text-xl text-brand-200 leading-relaxed">
            Haynes Industrial arranges transportation, finds the right buyers and recyclers, and manages compliance — so your end-of-life and surplus material earns money instead of costing you time.
          </p>

          <!-- CTAs -->
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/contact" class="btn-primary px-7 py-3.5 text-sm">
              Get In Touch
            </a>
            <a href="/services" class="btn-outline-white px-7 py-3.5 text-sm">
              Our Services
            </a>
          </div>

          <!-- Credential strip -->
          <div class="mt-14 flex flex-wrap items-center gap-x-6 gap-y-2 border-t border-brand-700/60 pt-8">
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-400">Licensed · Bonded · Insured</span>
            <span class="hidden sm:block h-4 w-px bg-brand-700"></span>
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-400">EPA 608 Certified</span>
            <span class="hidden sm:block h-4 w-px bg-brand-700"></span>
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-400">Licensed Transportation Provider</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── About ─────────────────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-center">

          <!-- Copy -->
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">About Haynes Industrial</p>
            <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">
              Who We Are
            </h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <p class="mt-8 text-lg text-gray-600 leading-relaxed">
              Haynes Industrial is a recycling logistics company. We figure out the best path for your end-of-life and surplus material — which buyers pay the most, which recyclers handle regulated material correctly, and how to move everything with the least friction.
            </p>
            <p class="mt-4 text-lg text-gray-600 leading-relaxed">
              We're a licensed transportation provider, so we can arrange the right carrier for every load — not just our own trucks. Add deep compliance expertise and established downstream relationships, and you get a single partner who handles the whole logistics problem.
            </p>
            <a href="/about" class="btn-primary mt-10 inline-flex">
              Learn More
            </a>
          </div>

          <!-- Image -->
          <div class="relative">
            <img
              src="/images/dump-trailer-haynes-industrial-logo.gif"
              alt="Haynes Industrial branded roll-off dumpster container at an industrial facility"
              class="w-full h-80 lg:h-[480px] object-cover"
              loading="lazy"
            />
            <!-- Corner accent -->
            <div class="absolute -bottom-4 -right-4 h-20 w-20 border-b-4 border-r-4 border-brand-600 hidden lg:block" aria-hidden="true"></div>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── Core Services ──────────────────────────────────────────────────── -->
    <section class="bg-brand-900 py-24 lg:py-32">
      <div class="section-container">

        <!-- Section header -->
        <div class="mb-14">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400">What We Do</p>
          <h2 class="mt-3 text-4xl font-bold text-white leading-tight">
            Core Services
          </h2>
          <div class="mt-3 h-1 w-10 bg-brand-500"></div>
          <p class="mt-6 text-lg text-brand-300 max-w-2xl leading-relaxed">
            Comprehensive recycling logistics and industrial services tailored to your needs.
          </p>
        </div>

        <!-- Cards: gap-px with bg-brand-700 creates the divider lines -->
        <div class="grid gap-px bg-brand-700 sm:grid-cols-2 lg:grid-cols-3">
          {services.map(({ number, title, image, imageAlt, description, href }) => (
            <div class="bg-brand-800 hover:bg-brand-700/80 transition-colors flex flex-col">
              <div class="overflow-hidden">
                <img
                  src={image}
                  alt={imageAlt}
                  class="w-full h-52 object-cover opacity-90 hover:opacity-100 transition-opacity"
                  loading="lazy"
                />
              </div>
              <div class="p-8 flex flex-col flex-1">
                <p class="text-4xl font-bold text-brand-600/70">{number}</p>
                <h3 class="mt-4 text-xl font-bold text-white leading-snug">{title}</h3>
                <p class="mt-4 text-sm text-brand-300 leading-relaxed flex-1">{description}</p>
                <a href={href} class="mt-8 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-400 no-underline hover:text-brand-200 transition-colors">
                  Learn More
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ─── Why Choose / Mission ───────────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="section-container">
        <div class="grid gap-14 lg:grid-cols-2 lg:items-start">

          <!-- Left: Why choose -->
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Our Commitment</p>
            <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">
              Why Haynes Industrial
            </h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <ul class="mt-10 space-y-0 list-none m-0 p-0 divide-y divide-gray-100">
              {whyUs.map((item) => (
                <li class="flex items-start gap-4 py-5">
                  <span class="mt-0.5 flex-shrink-0 h-5 w-5 bg-brand-600 flex items-center justify-center" aria-hidden="true">
                    <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-base text-gray-700 leading-snug">{item}</span>
                </li>
              ))}
            </ul>
            <a href="/services" class="btn-primary mt-10 inline-flex">
              View All Services
            </a>
          </div>

          <!-- Right: Mission panel -->
          <div class="bg-brand-800 p-10 lg:p-12">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400">Our Mission</p>
            <h3 class="mt-4 text-2xl font-bold text-white">Turning Waste Into Value</h3>
            <div class="mt-2 h-0.5 w-8 bg-brand-500"></div>
            <p class="mt-6 leading-relaxed text-brand-200">
              Businesses shouldn't have to figure out which recycler handles which material, navigate compliance on their own, or leave money on the table because they don't know what their end-of-life material is worth.
            </p>
            <p class="mt-4 leading-relaxed text-brand-200">
              We handle that — transportation, compliance, downstream relationships — from the first call to the final disposition receipt.
            </p>
            <a href="/contact" class="btn-white mt-10 inline-flex">
              Get In Touch
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── Testimonials ───────────────────────────────────────────────────── -->
    <section class="bg-gray-50 py-24 lg:py-32 overflow-hidden">
      <div class="section-container">

        <!-- Section header -->
        <div class="mb-14">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Client Testimonials</p>
          <h2 class="mt-3 text-4xl font-bold text-gray-900">What Clients Say</h2>
          <div class="mt-3 h-1 w-10 bg-brand-600"></div>
        </div>

        <!-- Carousel -->
        <div class="relative mx-auto max-w-2xl" id="testimonial-carousel" aria-roledescription="carousel" aria-label="Client testimonials">
          <div class="overflow-hidden">
            <div id="testimonial-track" class="flex transition-transform duration-500 ease-in-out">

              <!-- Slide 1 -->
              <div class="w-full flex-shrink-0" role="group" aria-roledescription="slide" aria-label="1 of 3">
                <div class="bg-white border border-gray-200 p-10">
                  <svg class="h-7 w-7 text-brand-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                  </svg>
                  <blockquote class="mt-6 text-lg text-gray-700 leading-relaxed italic">
                    "Haynes Industrial is our go-to for e-waste, batteries, lightbulbs, and appliances. They make the tough jobs simple and always find a way to handle the recycling and waste removal parts smoothly."
                  </blockquote>
                  <div class="mt-8 flex items-center gap-4 border-t border-gray-100 pt-6">
                    <img
                      src="/images/contractor-profile.avif"
                      alt="John A., General Contractor"
                      class="h-12 w-12 object-cover"
                      loading="lazy"
                    />
                    <div>
                      <p class="font-bold text-gray-900 text-sm">John A.</p>
                      <p class="text-xs text-gray-500 mt-0.5">General Contractor</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Slide 2 -->
              <div class="w-full flex-shrink-0" role="group" aria-roledescription="slide" aria-label="2 of 3">
                <div class="bg-white border border-gray-200 p-10">
                  <svg class="h-7 w-7 text-brand-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                  </svg>
                  <blockquote class="mt-6 text-lg text-gray-700 leading-relaxed italic">
                    "We do electrical, HVAC, and solar, and Haynes Industrial is the only company we trust with all our waste. They take care of everything from solar panels and light bulbs to old HVAC units. It's a relief to have one reliable partner who does it all."
                  </blockquote>
                  <div class="mt-8 flex items-center gap-4 border-t border-gray-100 pt-6">
                    <img
                      src="/images/warehouse-sup-profile.avif"
                      alt="Brad R., Warehouse Supervisor"
                      class="h-12 w-12 object-cover"
                      loading="lazy"
                    />
                    <div>
                      <p class="font-bold text-gray-900 text-sm">Brad R.</p>
                      <p class="text-xs text-gray-500 mt-0.5">Warehouse Supervisor</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Slide 3 -->
              <div class="w-full flex-shrink-0" role="group" aria-roledescription="slide" aria-label="3 of 3">
                <div class="bg-white border border-gray-200 p-10">
                  <svg class="h-7 w-7 text-brand-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                  </svg>
                  <blockquote class="mt-6 text-lg text-gray-700 leading-relaxed italic">
                    "When we had to replace more than 1,200 traffic lights for a city project, Haynes Industrial stepped in and made it easy. Their recycling solutions saved us time, money, and a lot of stress."
                  </blockquote>
                  <div class="mt-8 flex items-center gap-4 border-t border-gray-100 pt-6">
                    <img
                      src="/images/project-manager-profile.avif"
                      alt="Jeff G., Electrical Utilities Project Manager"
                      class="h-12 w-12 object-cover"
                      loading="lazy"
                    />
                    <div>
                      <p class="font-bold text-gray-900 text-sm">Jeff G.</p>
                      <p class="text-xs text-gray-500 mt-0.5">Electrical Utilities Project Manager</p>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>

          <!-- Prev / Next -->
          <button
            id="testimonial-prev"
            aria-label="Previous testimonial"
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-5 flex h-10 w-10 items-center justify-center bg-white shadow-md text-brand-700 hover:bg-brand-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-600"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </button>
          <button
            id="testimonial-next"
            aria-label="Next testimonial"
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 flex h-10 w-10 items-center justify-center bg-white shadow-md text-brand-700 hover:bg-brand-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-600"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </button>

          <!-- Dot indicators — active dot is a pill, inactive are squares -->
          <div class="mt-10 flex justify-center gap-2.5" role="tablist" aria-label="Testimonial slides">
            <button role="tab" aria-selected="true"  aria-label="Slide 1" data-index="0" class="testimonial-dot h-2 w-8 bg-brand-600 transition-all duration-300"></button>
            <button role="tab" aria-selected="false" aria-label="Slide 2" data-index="1" class="testimonial-dot h-2 w-2 bg-brand-200 transition-all duration-300 hover:bg-brand-400"></button>
            <button role="tab" aria-selected="false" aria-label="Slide 3" data-index="2" class="testimonial-dot h-2 w-2 bg-brand-200 transition-all duration-300 hover:bg-brand-400"></button>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── Instagram Feed ──────────────────────────────────────────────────── -->
    <section class="py-24 lg:py-32 bg-gray-50">
      <div class="section-container">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">Follow Along</p>
            <h2 class="mt-3 text-4xl font-bold text-gray-900 leading-tight">In the Field</h2>
            <div class="mt-3 h-1 w-10 bg-brand-600"></div>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              Real jobs, real material — copper bins, rooftop units coming down, and full trailer loads heading out. Follow us on Instagram to see what we're working on this week.
            </p>
            <a
              href="https://www.instagram.com/haynesindustrial"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center gap-3 no-underline group"
            >
              <span class="flex h-12 w-12 items-center justify-center bg-brand-600 group-hover:bg-brand-700 transition-colors">
                <svg class="h-6 w-6 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-bold text-gray-900 group-hover:text-brand-600 transition-colors">@haynesindustrial</p>
                <p class="text-xs text-gray-500">Follow on Instagram</p>
              </div>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-2">
            <img src="/images/copper-bin-metal.gif" alt="Overhead view of a bin of copper wire coils" class="w-full aspect-square object-cover" loading="lazy" />
            <img src="/images/hvac-crane-removal.avif" alt="Commercial HVAC unit being crane-lifted for removal" class="w-full aspect-square object-cover" loading="lazy" />
            <img src="/images/worker-loading-trailer.gif" alt="Haynes Industrial worker loading copper wire into a dump trailer" class="w-full aspect-square object-cover" loading="lazy" />
            <img src="/images/styrofoam-forklift-surplus.jpeg" alt="Forklift loading surplus Styrofoam blocks onto a flatbed trailer" class="w-full aspect-square object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ─── CTA Banner ────────────────────────────────────────────────────── -->
    <section class="bg-brand-800 py-20">
      <div class="section-container">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="text-3xl font-bold text-white lg:text-4xl">Put Us to Work</h2>
            <p class="mt-3 text-lg text-brand-200">
              Contact us today to discuss your recycling and logistics needs.
            </p>
          </div>
          <div class="flex-shrink-0">
            <a href="/contact" class="btn-white px-8 py-4 text-sm">
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <script>
    const track = document.getElementById('testimonial-track') as HTMLElement;
    const dots  = document.querySelectorAll<HTMLButtonElement>('.testimonial-dot');
    const total = 3;
    let current = 0;

    function goTo(index: number) {
      current = (index + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle('bg-brand-600', active);
        d.classList.toggle('w-8',          active);
        d.classList.toggle('bg-brand-200', !active);
        d.classList.toggle('w-2',          !active);
        d.setAttribute('aria-selected', String(active));
      });
    }

    document.getElementById('testimonial-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('testimonial-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot) => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));
  </script>

</BaseLayout>
