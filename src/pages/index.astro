---
/**
 * src/pages/index.astro — Home page
 *
 * Shows a hero section and the three most recent published blog posts.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Astro Template"
  description="A production-ready Astro blog template with Tailwind CSS, MDX, and CloudCannon CMS support."
>
  <main>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-50 to-white dark:from-gray-900 dark:to-gray-950">
    <div class="mx-auto max-w-4xl px-4 py-24 sm:px-6 text-center">
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 dark:text-white text-balance">
        Welcome to<br />
        <span class="text-brand-600 dark:text-brand-400">Astro Template</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-xl text-gray-600 dark:text-gray-400 text-pretty">
        A production-ready starter with Astro, Tailwind CSS, MDX, content
        collections, CloudCannon CMS integration, and Netlify deployment.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/blog" class="btn-primary">
          Read the blog
        </a>
        <a href="/about" class="btn-secondary">
          About this template
        </a>
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  {recentPosts.length > 0 && (
    <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">
          Recent Posts
        </h2>
        <a
          href="/blog"
          class="text-sm font-medium text-brand-600 no-underline hover:underline dark:text-brand-400"
        >
          View all →
        </a>
      </div>

      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none m-0 p-0">
        {recentPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block card h-full no-underline">
              {post.data.heroImage && (
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="mb-4 h-40 w-full rounded-lg object-cover"
                  loading="lazy"
                  width={600}
                  height={315}
                />
              )}

              {post.data.tags.length > 0 && (
                <div class="mb-2 flex flex-wrap gap-1">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="tag-pill">{tag}</span>
                  ))}
                </div>
              )}

              <h3 class="text-lg font-semibold text-gray-900 group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400 transition-colors text-balance">
                {post.data.title}
              </h3>

              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-3">
                {post.data.description}
              </p>

              <p class="mt-4 text-xs">
                <FormattedDate date={post.data.pubDate} format="short" />
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Feature highlights -->
  <section class="bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
      <h2 class="mb-10 text-center text-2xl font-semibold text-gray-900 dark:text-white">
        What's included
      </h2>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none m-0 p-0">
        {[
          { emoji: '⚡', title: 'Astro + TypeScript', desc: 'Zero-JS by default with full type safety.' },
          { emoji: '🎨', title: 'Tailwind CSS', desc: 'Utility-first styling with dark mode support.' },
          { emoji: '📝', title: 'MDX Blog', desc: 'Write posts in Markdown with JSX components.' },
          { emoji: '🗺️', title: 'Sitemap & RSS', desc: 'Auto-generated sitemap.xml and RSS feed.' },
          { emoji: '🔒', title: 'Security Headers', desc: 'Production-ready headers via Netlify.' },
          { emoji: '🧪', title: 'Testing', desc: 'Vitest unit tests + Playwright E2E tests.' },
        ].map(({ emoji, title, desc }) => (
          <li class="card">
            <p class="text-3xl mb-3" aria-hidden="true">{emoji}</p>
            <h3 class="font-semibold text-gray-900 dark:text-white">{title}</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
  </main>
</BaseLayout>
