---
import BaseLayout from '@/layouts/BaseLayout.astro';

const AUDIENCE = [
  { label: 'General Contractors', href: '/services' },
  { label: 'Property Managers', href: '/services' },
  { label: 'Manufacturing & Industrial', href: '/services' },
  { label: 'Medical & Lab Facilities', href: '/services' },
];

const TRUST_ITEMS = [
  'Licensed & Bonded',
  'Fully Insured',
  'Northern & Central California',
  'Certified Refrigerant Recovery',
];

const SERVICES = [
  {
    number: '01',
    title: 'Universal Waste Management',
    image: '/images/waste-bins.avif',
    imageAlt: 'Industrial waste bins ready for collection',
    description:
      'Complete solutions for universal waste — safe handling, regulatory compliance, and maximum recovery of reusable materials. Our services reduce environmental risks and make waste management seamless.',
  },
  {
    number: '02',
    title: 'Medical & Lab Equipment Disposal',
    image: '/images/lab-equipment.avif',
    imageAlt: 'Laboratory equipment staged for disposal',
    description:
      'Secure, compliant disposal of medical and laboratory equipment, including decontamination, dismantling, and responsible recycling. Our processes meet regulatory requirements and ensure sensitive materials are handled with care.',
  },
  {
    number: '03',
    title: 'HVAC & Appliance Recycling',
    image: '/images/hvac.avif',
    imageAlt: 'HVAC unit ready for recycling',
    description:
      'Comprehensive HVAC and appliance recycling, including certified refrigerant recovery and responsible dismantling. We ensure regulatory compliance while making end-of-life equipment management simple and efficient.',
  },
];

const WHY_ITEMS = [
  'Full-service partner for industrial recycling, e-waste, and equipment decommissioning',
  'Licensed, bonded, and insured',
  'Proven expertise across diverse industrial sectors',
  'Commitment to safety, sustainability, and compliance',
  'Customized solutions that save time, reduce costs, and maximize value',
];

const TESTIMONIALS = [
  {
    quote:
      "Haynes Industrial is our go-to for e-waste, batteries, lightbulbs, and appliances. They make the tough jobs simple and always find a way to handle the recycling and waste removal parts smoothly.",
    name: 'John A.',
    role: 'General Contractor',
    image: '/images/contractor-profile.avif',
  },
  {
    quote:
      "We do electrical, HVAC, and solar, and Haynes Industrial is the only company we trust with all our waste. They take care of everything from solar panels and light bulbs to old HVAC units. It's a relief to have one reliable partner who does it all.",
    name: 'Brad R.',
    role: 'Warehouse Supervisor',
    image: '/images/warehouse-sup-profile.avif',
  },
  {
    quote:
      "When we had to replace more than 1,200 traffic lights for a city project, Haynes Industrial stepped in and made it easy. Their recycling solutions saved us time, money, and a lot of stress.",
    name: 'Jeff G.',
    role: 'Electrical Utilities Project Manager',
    image: '/images/project-manager-profile.avif',
  },
];
---

<BaseLayout
  title="Haynes Industrial"
  description="A trusted partner for industrial recycling and universal waste management in Northern California. Turning waste into value."
>
  <main>

    <!-- ─── Hero ──────────────────────────────────────────────────────────────── -->
    <section class="relative isolate overflow-hidden min-h-[88vh] grid grid-cols-1 lg:grid-cols-[58%_42%]">

      <!-- Mobile background image (lg: hidden — right column takes over) -->
      <div class="absolute inset-0 -z-10 lg:hidden">
        <img
          src="/images/loaded-truck-pipe.avif"
          alt=""
          aria-hidden="true"
          class="h-full w-full object-cover"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-brand-900/88"></div>
      </div>

      <!-- Left: text column -->
      <div class="flex flex-col justify-center px-6 py-24 sm:px-12 lg:bg-brand-900 lg:px-14 xl:px-20">
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-300 mb-8">
          Environmental Services · Northern &amp; Central California
        </p>
        <h1
          class="font-display text-6xl font-bold leading-[1.05] tracking-tight text-white lg:text-7xl"
        >
          Waste Removed.<br />
          Value Recovered.
        </h1>
        <p class="mt-8 max-w-sm text-lg leading-relaxed text-brand-200">
          A trusted partner for industrial recycling and universal waste management in Northern California.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary">Get In Touch</a>
          <a href="/services" class="btn-outline-white">Our Services</a>
        </div>
      </div>

      <!-- Right: atmospheric image (desktop only) -->
      <div class="relative hidden lg:block">
        <img
          src="/images/loaded-truck-pipe.avif"
          alt=""
          aria-hidden="true"
          class="absolute inset-0 h-full w-full object-cover"
          fetchpriority="high"
        />
      </div>
    </section>

    <!-- ─── Audience Self-Select ──────────────────────────────────────────────── -->
    <section class="bg-brand-800 border-b border-brand-700">
      <div class="section-container py-4">
        <div class="flex flex-wrap items-center gap-x-2 gap-y-2">
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-brand-400 mr-4 shrink-0">
            I work in
          </span>
          {AUDIENCE.map(({ label, href }) => (
            <a
              href={href}
              class="border border-brand-600 px-4 py-2 text-sm font-medium text-brand-200 no-underline transition-colors hover:border-brand-300 hover:bg-brand-700 hover:text-white"
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Trust Strip ───────────────────────────────────────────────────────── -->
    <section class="border-b border-gray-100 bg-white py-6">
      <div class="section-container">
        <ul class="flex flex-wrap items-center gap-0 list-none m-0 p-0 divide-x divide-gray-200">
          {TRUST_ITEMS.map((item) => (
            <li class="px-6 first:pl-0 last:pr-0">
              <span class="text-xs font-bold uppercase tracking-[0.14em] text-gray-500">
                {item}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ─── About ─────────────────────────────────────────────────────────────── -->
    <section class="py-24">
      <div class="section-container">
        <div class="max-w-2xl">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500 mb-6">About Us</p>
          <h2 class="text-5xl font-bold text-gray-900 leading-tight lg:text-6xl">
            Built on Expertise,<br />Driven by Responsibility
          </h2>
          <div class="mt-8 space-y-4 text-lg text-gray-600 leading-relaxed">
            <p>
              Haynes Industrial provides integrated recycling and waste management services to industrial and commercial sectors across Northern and Central California. We are committed to advancing sustainability through regulatory compliance, operational efficiency, and resource recovery.
            </p>
            <p>
              Our team brings deep expertise in handling complex waste streams and delivering scalable, cost-effective solutions that align with industry best practices and environmental standards.
            </p>
          </div>
          <a href="/about" class="btn-primary mt-10 inline-flex">Learn More</a>
        </div>
      </div>
    </section>

    <!-- ─── Core Services ─────────────────────────────────────────────────────── -->
    <section class="bg-gray-50 py-24">
      <div class="section-container">
        <div class="mb-16">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500 mb-6">What We Do</p>
          <h2 class="text-5xl font-bold text-gray-900 lg:text-6xl">Core Services</h2>
        </div>

        <div class="grid gap-12 sm:grid-cols-3">
          {SERVICES.map(({ number, title, image, imageAlt, description }) => (
            <article class="flex flex-col border-t-2 border-brand-600 pt-7">
              <span class="text-sm font-bold tracking-[0.15em] text-brand-400 mb-5">{number}</span>
              <div class="mb-6 overflow-hidden">
                <img
                  src={image}
                  alt={imageAlt}
                  class="w-full h-44 object-cover"
                  loading="lazy"
                />
              </div>
              <h3 class="text-xl font-bold text-gray-900 leading-snug">{title}</h3>
              <p class="mt-3 text-sm text-gray-600 leading-relaxed flex-1">{description}</p>
              <a
                href="/services"
                class="mt-6 inline-flex text-sm font-semibold text-brand-600 no-underline hover:underline tracking-wide"
              >
                Learn More →
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Why Choose Us ─────────────────────────────────────────────────────── -->
    <section class="py-24">
      <div class="section-container">
        <div class="grid gap-16 lg:grid-cols-2 lg:items-start">

          <!-- Bullet list -->
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500 mb-6">Why Us</p>
            <h2 class="text-4xl font-bold text-gray-900 leading-tight lg:text-5xl">
              Why Contractors Choose Haynes
            </h2>
            <ul class="mt-10 space-y-5 list-none m-0 p-0">
              {WHY_ITEMS.map((item) => (
                <li class="flex items-start gap-4">
                  <span class="flex-shrink-0 mt-0.5 h-5 w-5 bg-brand-600 flex items-center justify-center">
                    <svg
                      class="h-3 w-3 text-white"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="3"
                      aria-hidden="true"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </span>
                  <span class="text-gray-700 leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
            <a href="/services" class="btn-primary mt-12 inline-flex">View All Services</a>
          </div>

          <!-- Mission block -->
          <div class="bg-brand-900 p-10 text-white lg:mt-20">
            <h3 class="text-2xl font-bold">Our Mission</h3>
            <p class="mt-4 leading-relaxed text-brand-200">
              At Haynes Industrial, our mission is to provide safe, reliable, and sustainable recycling and waste management solutions that help businesses reduce environmental impact, stay compliant, and recover valuable resources.
            </p>
            <p class="mt-4 leading-relaxed text-brand-200">
              We are committed to supporting our clients, our communities, and the planet through responsible practices and innovative services.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── Testimonials ──────────────────────────────────────────────────────── -->
    <section class="bg-gray-50 py-24">
      <div class="section-container">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500 mb-6">
          Client Testimonials
        </p>
        <h2 class="text-4xl font-bold text-gray-900 mb-14 lg:text-5xl">What Our Clients Say</h2>

        <div
          class="relative mx-auto max-w-2xl"
          id="testimonial-carousel"
          aria-roledescription="carousel"
          aria-label="Client testimonials"
        >
          <div class="overflow-hidden">
            <div id="testimonial-track" class="flex transition-transform duration-500 ease-in-out">

              {TESTIMONIALS.map(({ quote, name, role, image }, i) => (
                <div
                  class="w-full flex-shrink-0"
                  role="group"
                  aria-roledescription="slide"
                  aria-label={`${i + 1} of ${TESTIMONIALS.length}`}
                >
                  <div class="border-t-2 border-brand-600 pt-8">
                    <svg
                      class="h-9 w-9 text-brand-200 mb-6"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                    </svg>
                    <blockquote class="text-xl text-gray-800 leading-relaxed italic">
                      "{quote}"
                    </blockquote>
                    <div class="mt-8 flex items-center gap-4">
                      <img
                        src={image}
                        alt={name}
                        class="h-12 w-12 rounded-full object-cover flex-shrink-0"
                        loading="lazy"
                      />
                      <div>
                        <p class="font-bold text-gray-900">{name}</p>
                        <p class="text-sm text-gray-500">{role}</p>
                      </div>
                    </div>
                  </div>
                </div>
              ))}

            </div>
          </div>

          <!-- Prev / Next buttons -->
          <button
            id="testimonial-prev"
            aria-label="Previous testimonial"
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-5 flex h-10 w-10 items-center justify-center bg-white border border-gray-200 text-brand-700 hover:bg-brand-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-600"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </button>
          <button
            id="testimonial-next"
            aria-label="Next testimonial"
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 flex h-10 w-10 items-center justify-center bg-white border border-gray-200 text-brand-700 hover:bg-brand-50 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-brand-600"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </button>

          <!-- Dot indicators -->
          <div class="mt-8 flex justify-start gap-3" role="tablist" aria-label="Testimonial slides">
            {TESTIMONIALS.map((_, i) => (
              <button
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-label={`Slide ${i + 1}`}
                data-index={i}
                class:list={[
                  'testimonial-dot h-2.5 w-2.5 rounded-full transition-all',
                  i === 0 ? 'bg-brand-600' : 'bg-brand-200 hover:bg-brand-400',
                ]}
              />
            ))}
          </div>
        </div>
      </div>
    </section>

    <script>
      const track = document.getElementById('testimonial-track') as HTMLElement;
      const dots = document.querySelectorAll<HTMLButtonElement>('.testimonial-dot');
      const total = 3;
      let current = 0;

      function goTo(index: number) {
        current = (index + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        dots.forEach((d, i) => {
          const active = i === current;
          d.classList.toggle('bg-brand-600', active);
          d.classList.toggle('bg-brand-200', !active);
          d.setAttribute('aria-selected', String(active));
        });
      }

      document.getElementById('testimonial-prev')?.addEventListener('click', () => goTo(current - 1));
      document.getElementById('testimonial-next')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot) => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));
    </script>

    <!-- ─── CTA Banner ────────────────────────────────────────────────────────── -->
    <section class="bg-brand-900 py-20">
      <div class="section-container">
        <div class="max-w-xl">
          <h2 class="text-4xl font-bold text-white leading-tight lg:text-5xl">
            Let's Talk About Your Project
          </h2>
          <p class="mt-5 text-lg text-brand-200">
            Contact us today to discuss your recycling and waste management needs.
          </p>
          <a href="/contact" class="btn-white mt-8 inline-flex">Contact Us</a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
